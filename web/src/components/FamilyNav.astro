---
interface Props {
  active: 'nebelhaus' | 'pounce' | 'trill';
  productName?: string;
  productLogo?: string;
  guideHref?: string;
  repoHref?: string;
}

const {
  active,
  productName = 'nebelhaus',
  productLogo = '/logos/nebelhaus-mark-fill.png',
  guideHref = '/start/what-is-nebelhaus/',
  repoHref = 'https://github.com/nebelhaus',
} = Astro.props;

const assetV = '2';
---

<header class="family-nav" data-active={active}>
  <a class="family-brand" href="/">
    <img src={`${productLogo}?v=${assetV}`} alt="" width="28" height="28" />
    <span>{productName}</span>
  </a>

  <nav class="family-switcher" aria-label="Nebelhaus products">
    <a href="/" aria-current={active === 'nebelhaus' ? 'page' : undefined}>
      <span class="switcher-dot rice"></span>
      <span>nebelhaus</span>
    </a>
    <a href="/pounce/" aria-current={active === 'pounce' ? 'page' : undefined}>
      <span class="switcher-dot pounce"></span>
      <span>pounce</span>
    </a>
    <a href="/trill/" aria-current={active === 'trill' ? 'page' : undefined}>
      <span class="switcher-dot trill"></span>
      <span>trill</span>
    </a>
  </nav>

  <nav class="family-links" aria-label={`${productName} navigation`}>
    <a href={guideHref}>{active === 'nebelhaus' ? 'Docs' : 'Guide'}</a>
    {active === 'nebelhaus' && <a class="install-link" href="/start/install/">Install</a>}
    <a href={repoHref}>GitHub</a>
  </nav>
</header>

<style>
  .family-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.25rem;
    width: min(1080px, calc(100% - 3rem));
    margin: 0 auto;
    padding: 1.2rem 0;
  }

  .family-brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: max-content;
    color: var(--text);
    font-size: 1.05rem;
    font-weight: 650;
    text-decoration: none;
  }

  .family-brand:hover {
    color: var(--text);
  }

  .family-brand img {
    border-radius: 7px;
    object-fit: contain;
  }

  .family-switcher {
    display: flex;
    align-items: center;
    gap: 0.18rem;
    padding: 0.22rem;
    background: color-mix(in srgb, var(--mantle) 86%, transparent);
    border: 1px solid var(--surface0);
    border-radius: 999px;
  }

  .family-switcher a {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.38rem 0.68rem;
    border-radius: 999px;
    color: var(--overlay1);
    font-family: var(--mono);
    font-size: 0.72rem;
    line-height: 1;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .family-switcher a:hover {
    color: var(--text);
  }

  .family-switcher a[aria-current='page'] {
    background: var(--surface0);
    color: var(--text);
  }

  .switcher-dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
  }

  .switcher-dot.rice {
    background: var(--pink);
  }

  .switcher-dot.pounce {
    background: var(--peach);
  }

  .switcher-dot.trill {
    background: var(--blue);
  }

  .family-links {
    display: flex;
    justify-content: flex-end;
    gap: 1.3rem;
    font-size: 0.92rem;
  }

  .family-links a {
    color: var(--subtext0);
    text-decoration: none;
  }

  .family-links a:hover {
    color: var(--text);
  }

  @media (max-width: 780px) {
    .family-nav {
      grid-template-columns: 1fr auto;
      width: min(100% - 2rem, 1080px);
      padding: 1rem 0 0.75rem;
    }

    .family-switcher {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-self: center;
      order: 3;
    }

    .family-links {
      gap: 0.9rem;
      font-size: 0.86rem;
    }
  }

  @media (max-width: 430px) {
    .family-switcher a {
      padding-inline: 0.58rem;
      font-size: 0.68rem;
    }

    .family-links .install-link {
      display: none;
    }
  }
</style>
