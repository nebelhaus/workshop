---
import FamilyNav from '../components/FamilyNav.astro';

interface Feature {
  category: string;
  title: string;
  blurb: string;
  accent: string;
}

interface Props {
  product: 'pounce' | 'trill';
  accent: string;
  accentHover: string;
  logo: string;
  eyebrow: string;
  titleLead: string;
  titleAccent: string;
  lede: string;
  description: string;
  install: string;
  installMarkup: {
    command: string;
    flag?: string;
    formula: string;
  };
  standaloneCopy: string;
  riceCopy: string;
  riceHref: string;
  guideHref: string;
  repoHref: string;
  featuresLabel: string;
  featuresTitle: string;
  featuresCopy: string;
  features: Feature[];
  closerStatus: string;
  closerTitle: string;
  closerCopy: string;
  closerPrimaryLabel: string;
  closerPrimaryHref: string;
}

const props = Astro.props;
const {
  product,
  accent,
  accentHover,
  logo,
  eyebrow,
  titleLead,
  titleAccent,
  lede,
  description,
  install,
  installMarkup,
  standaloneCopy,
  riceCopy,
  riceHref,
  guideHref,
  repoHref,
  featuresLabel,
  featuresTitle,
  featuresCopy,
  features,
  closerStatus,
  closerTitle,
  closerCopy,
  closerPrimaryLabel,
  closerPrimaryHref,
} = props;
const title = `${product} — ${titleLead} ${titleAccent}`;
const canonical = `https://nebelhaus.com/${product}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={product} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://nebelhaus.com/social/og.png" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://nebelhaus.com/social/og.png" />
    <meta name="theme-color" content="#202020" />
  </head>
  <body
    data-product={product}
    style={`--product-accent: ${accent}; --product-accent-hover: ${accentHover}`}
  >
    <div class="fog" aria-hidden="true"></div>

    <FamilyNav
      active={product}
      productName={product}
      productLogo={logo}
      guideHref={guideHref}
      repoHref={repoHref}
    />

    <main>
      <section class="hero">
        <img class="hero-mark" src={`${logo}?v=2`} alt="" width="78" height="78" />
        <p class="eyebrow">{eyebrow}</p>
        <h1>{titleLead}<br /><span class="accent-text">{titleAccent}</span></h1>
        <p class="lede">{lede}</p>

        <div class="install">
          <p class="install-label">install standalone with homebrew</p>
          <div class="install-row">
            <code id="install-cmd" data-command={install} aria-label={install}>
              <span class="prompt">$</span>
              <span class="command">{installMarkup.command}</span>
              {installMarkup.flag && <span class="flag">{installMarkup.flag}</span>}
              <span class="formula">{installMarkup.formula}</span>
            </code>
            <button id="copy" aria-label={`Copy ${product} install command`} title="Copy">
              <span class="copy-idle">Copy</span>
              <span class="copy-done">Copied ✓</span>
            </button>
          </div>
        </div>

        <div class="install-paths" aria-label="Installation choices">
          <div class="path-card standalone">
            <span class="path-kicker">Just {product}</span>
            <p>{standaloneCopy}</p>
          </div>
          <a class="path-card rice" href={riceHref}>
            <span class="path-kicker">The whole rice</span>
            <p>{riceCopy}</p>
            <span class="path-link">Meet nebelhaus →</span>
          </a>
        </div>
      </section>

      <section class="features" aria-labelledby="feature-title">
        <div class="feature-head">
          <div>
            <p class="section-label">{featuresLabel}</p>
            <h2 id="feature-title">{featuresTitle}</h2>
            <p>{featuresCopy}</p>
          </div>
          <div class="rail-controls" aria-label="Feature list controls">
            <button type="button" data-scroll="-1" aria-label="Previous features">←</button>
            <button type="button" data-scroll="1" aria-label="Next features">→</button>
          </div>
        </div>

        <div class="feature-rail" data-feature-rail tabindex="0">
          {
            features.map((feature, index) => (
              <article class="feature-card" style={`--accent: ${feature.accent}`}>
                <div class="feature-meta">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <span>{feature.category}</span>
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.blurb}</p>
              </article>
            ))
          }
        </div>
        <p class="swipe-note">drag, swipe, or use the arrows</p>
      </section>

      <section class="closer">
        <div class="panel-title" aria-hidden="true">
          <span class="status-dot"></span>
          <span>{product}.app</span>
          <span class="status">{closerStatus}</span>
        </div>
        <div class="closer-grid">
          <h2>{closerTitle}</h2>
          <div>
            <p>{closerCopy}</p>
            <div class="cta closer-cta">
              <a class="btn btn-primary" href={closerPrimaryHref}>{closerPrimaryLabel}</a>
              <a class="btn btn-ghost" href={repoHref}>See the source</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-inner">
        <a class="footer-house" href="/">🌫 nebelhaus · raised in the fog</a>
        <nav>
          <a href={guideHref}>Guide</a>
          <a href={repoHref}>GitHub</a>
          <a href={`${repoHref}/blob/main/LICENSE`}>MIT</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      const copyButton = document.getElementById('copy');
      const installCommand = document.getElementById('install-cmd')?.dataset.command;

      copyButton?.addEventListener('click', async () => {
        if (!installCommand) return;
        try {
          await navigator.clipboard.writeText(installCommand);
          copyButton.classList.add('done');
          setTimeout(() => copyButton.classList.remove('done'), 1600);
        } catch (_) {
          /* clipboard blocked — no-op */
        }
      });

      const rail = document.querySelector('[data-feature-rail]');
      document.querySelectorAll('[data-scroll]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!rail) return;
          const direction = Number(button.dataset.scroll);
          rail.scrollBy({ left: direction * rail.clientWidth * 0.72, behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      :root {
        --base: #202020;
        --mantle: #191919;
        --crust: #121212;
        --surface0: #343434;
        --surface1: #494949;
        --surface2: #5c5c5c;
        --text: #d7d7d7;
        --subtext1: #c3c3c3;
        --subtext0: #aeaeae;
        --overlay1: #858585;
        --pink: #f2c4e5;
        --mauve: #c9a8f1;
        --peach: #f5b58e;
        --teal: #9be0d5;
        --green: #abe1a6;
        --blue: #8db4f3;
        --lavender: #b5bff8;
        --font: ui-sans-serif, system-ui, -apple-system, 'SF Pro Text', 'Segoe UI',
          Roboto, Helvetica, Arial, sans-serif;
        --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Fira Code', Menlo,
          Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--base);
        color: var(--text);
        font-family: var(--font);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .fog {
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(58% 33% at 50% -6%, color-mix(in srgb, var(--product-accent) 12%, transparent), transparent 76%),
          var(--base);
      }

      ::selection {
        background: var(--product-accent);
        color: var(--crust);
      }

      a {
        color: var(--product-accent);
        text-decoration: none;
      }

      a:hover {
        color: var(--product-accent-hover);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .hero {
        padding: 3.65rem 0 5.5rem;
        text-align: center;
      }

      .hero-mark {
        display: block;
        margin: 0 auto 1rem;
        border-radius: 18px;
        object-fit: contain;
        filter: drop-shadow(0 12px 32px color-mix(in srgb, var(--product-accent) 16%, transparent));
      }

      .eyebrow,
      .section-label,
      .install-label {
        margin: 0 0 1.1rem;
        color: var(--overlay1);
        font-family: var(--mono);
        font-size: 0.76rem;
        letter-spacing: 0.055em;
        text-transform: lowercase;
      }

      .hero h1 {
        margin: 0 0 1rem;
        font-size: clamp(2.6rem, 6.2vw, 4.4rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.02;
      }

      .accent-text {
        color: var(--product-accent);
      }

      .lede {
        max-width: 690px;
        margin: 0 auto 2.25rem;
        color: var(--subtext0);
        font-family: var(--mono);
        font-size: 0.97rem;
      }

      .install {
        max-width: 680px;
        margin: 0 auto 1rem;
      }

      .install-label {
        margin-bottom: 0.55rem;
      }

      .install-row {
        display: flex;
        align-items: stretch;
        gap: 0.5rem;
        padding: 0.5rem 0.55rem 0.5rem 1rem;
        background: var(--crust);
        border: 1px solid color-mix(in srgb, var(--product-accent) 38%, var(--surface0));
        border-radius: 10px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.14);
      }

      .install-row code {
        display: flex;
        flex: 1;
        min-width: 0;
        align-items: center;
        gap: 0.55em;
        overflow-x: auto;
        color: var(--text);
        font-family: var(--mono);
        font-size: 0.95rem;
        text-align: left;
        white-space: nowrap;
      }

      .install-row .prompt {
        margin-right: 0.2rem;
        color: var(--mauve);
      }

      .install-row .command {
        color: var(--pink);
      }

      .install-row .flag {
        color: var(--peach);
      }

      .install-row .formula {
        color: var(--teal);
      }

      #copy {
        flex-shrink: 0;
        padding: 0 0.95rem;
        background: var(--product-accent);
        border: 1px solid var(--product-accent);
        border-radius: 7px;
        color: var(--crust);
        cursor: pointer;
        font-family: var(--font);
        font-size: 0.85rem;
        font-weight: 650;
      }

      #copy:hover {
        background: var(--product-accent-hover);
        border-color: var(--product-accent-hover);
      }

      #copy .copy-done {
        display: none;
      }

      #copy.done .copy-idle {
        display: none;
      }

      #copy.done .copy-done {
        display: inline;
      }

      .install-paths {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        max-width: 680px;
        margin: 0 auto;
        text-align: left;
      }

      .path-card {
        display: block;
        min-height: 124px;
        padding: 1rem 1.1rem;
        background: color-mix(in srgb, var(--mantle) 87%, transparent);
        border: 1px solid var(--surface0);
        border-radius: 9px;
        color: var(--text);
      }

      .path-card.rice {
        border-color: color-mix(in srgb, var(--pink) 38%, var(--surface0));
        transition: background 0.15s, border-color 0.15s;
      }

      .path-card.rice:hover {
        background: #1c1c1c;
        border-color: var(--pink);
        color: var(--text);
      }

      .path-kicker {
        color: var(--product-accent);
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.045em;
        text-transform: uppercase;
      }

      .path-card.rice .path-kicker,
      .path-link {
        color: var(--pink);
      }

      .path-card p {
        margin: 0.35rem 0 0;
        color: var(--subtext0);
        font-size: 0.84rem;
        line-height: 1.45;
      }

      .path-link {
        display: block;
        margin-top: 0.5rem;
        font-size: 0.8rem;
        font-weight: 650;
      }

      .features {
        margin: 0 0 5.5rem;
      }

      .feature-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 1.5rem;
      }

      .feature-head .section-label {
        margin-bottom: 0.65rem;
        color: var(--product-accent);
      }

      .feature-head h2,
      .closer h2 {
        margin: 0 0 0.6rem;
        font-size: clamp(1.8rem, 4vw, 2.7rem);
        letter-spacing: -0.025em;
        line-height: 1.12;
      }

      .feature-head > div > p:last-child {
        max-width: 680px;
        margin: 0;
        color: var(--subtext0);
      }

      .rail-controls {
        display: flex;
        flex-shrink: 0;
        gap: 0.45rem;
      }

      .rail-controls button {
        width: 2.7rem;
        height: 2.7rem;
        background: var(--mantle);
        border: 1px solid var(--surface1);
        border-radius: 7px;
        color: var(--text);
        cursor: pointer;
        font-family: var(--mono);
        font-size: 1rem;
      }

      .rail-controls button:hover {
        background: var(--surface0);
        border-color: var(--surface2);
      }

      .feature-rail {
        display: flex;
        gap: 0.8rem;
        padding: 0 0 0.7rem;
        overflow-x: auto;
        overscroll-behavior-x: contain;
        scroll-behavior: smooth;
        scroll-snap-type: x mandatory;
        scrollbar-color: var(--surface2) var(--mantle);
        scrollbar-width: thin;
      }

      .feature-card {
        display: flex;
        flex: 0 0 250px;
        flex-direction: column;
        min-height: 220px;
        padding: 1.15rem;
        background: var(--mantle);
        border: 1px solid var(--surface0);
        border-top: 3px solid var(--accent);
        border-radius: 9px;
        scroll-snap-align: start;
      }

      .feature-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: var(--accent);
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .feature-card h3 {
        margin: auto 0 0.55rem;
        color: var(--text);
        font-size: 1.16rem;
        letter-spacing: -0.015em;
        line-height: 1.2;
      }

      .feature-card p {
        margin: 0;
        color: var(--subtext0);
        font-size: 0.88rem;
        line-height: 1.5;
      }

      .swipe-note {
        margin: 0.65rem 0 0;
        color: var(--overlay1);
        font-family: var(--mono);
        font-size: 0.72rem;
        text-align: right;
      }

      .closer {
        margin: 5.5rem 0;
        background: var(--mantle);
        border: 1px solid color-mix(in srgb, var(--product-accent) 24%, var(--surface0));
        border-radius: 11px;
      }

      .panel-title {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 0.9rem;
        border-bottom: 1px solid var(--surface0);
        color: var(--overlay1);
        font-family: var(--mono);
        font-size: 0.72rem;
      }

      .status-dot {
        width: 0.5rem;
        height: 0.5rem;
        background: var(--green);
        border-radius: 50%;
      }

      .panel-title .status {
        margin-left: auto;
        color: var(--green);
      }

      .closer-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        align-items: center;
        gap: 3rem;
        padding: 2.5rem;
      }

      .closer h2 {
        margin: 0;
        font-size: clamp(2rem, 4.6vw, 3.2rem);
      }

      .closer-grid p {
        margin: 0 0 1.5rem;
        color: var(--subtext0);
      }

      .cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.68rem 1.35rem;
        border: 1px solid transparent;
        border-radius: 8px;
        font-size: 0.96rem;
        font-weight: 580;
        transition: background 0.15s, border-color 0.15s;
      }

      .btn-primary {
        background: var(--product-accent);
        color: var(--crust);
      }

      .btn-primary:hover {
        background: var(--product-accent-hover);
        color: var(--crust);
      }

      .btn-ghost {
        background: var(--crust);
        border-color: var(--surface1);
        color: var(--text);
      }

      .btn-ghost:hover {
        border-color: var(--surface2);
        color: var(--text);
      }

      .foot {
        margin-top: 3rem;
        border-top: 1px solid var(--surface0);
      }

      .foot-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        max-width: 1080px;
        margin: 0 auto;
        padding: 1.8rem 1.5rem;
        gap: 1rem;
        color: var(--overlay1);
        font-size: 0.9rem;
      }

      .footer-house {
        color: var(--overlay1);
      }

      .foot-inner nav {
        display: flex;
        gap: 1.3rem;
      }

      .foot-inner nav a {
        color: var(--subtext0);
      }

      @media (max-width: 640px) {
        main {
          padding: 0 1rem;
        }

        .hero {
          padding: 2.9rem 0 4.5rem;
        }

        .hero-mark {
          width: 64px;
          height: 64px;
        }

        .eyebrow {
          font-size: 0.68rem;
        }

        .install-row {
          padding-left: 0.78rem;
        }

        .install-row code {
          gap: 0.46em;
          font-size: 0.76rem;
        }

        #copy {
          padding-inline: 0.72rem;
        }

        .install-paths {
          grid-template-columns: 1fr;
        }

        .path-card {
          min-height: auto;
        }

        .feature-head {
          align-items: flex-end;
          gap: 0.75rem;
        }

        .feature-head > div:first-child {
          flex: 1;
          min-width: 0;
        }

        .feature-head > div > p:last-child {
          font-size: 0.9rem;
        }

        .feature-card {
          flex-basis: min(78vw, 265px);
        }

        .swipe-note {
          text-align: left;
        }

        .closer-grid {
          grid-template-columns: 1fr;
          gap: 1.4rem;
          padding: 1.6rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html,
        .feature-rail {
          scroll-behavior: auto;
        }
      }
    </style>
  </body>
</html>
