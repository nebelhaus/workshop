---
// nebelhaus.com — the landing page. Fully custom (not the Starlight layout).
// Kept deliberately simple: the install one-liner is the hero; everything else
// points at the docs and GitHub.
const desc =
  'An opinionated macOS, raised in the fog. Silver-grey, keyboard-first, reproducible, Nix-native. One curl and one Nix flake raise the whole house.';
const install = 'curl -fsSL https://nebelhaus.com/init.sh | bash';

const family = [
  {
    name: 'nebelhaus',
    logo: '/logos/nebelhaus.png',
    tagline: 'the rice',
    blurb:
      'nix-darwin modules for tiling, a status bar, the shell, and Touch-ID sudo — the whole system as text.',
    href: 'https://github.com/nebelhaus/nebelhaus',
  },
  {
    name: 'pounce',
    logo: '/logos/pounce-peeking.png',
    tagline: 'the launcher',
    blurb:
      'a native, keyboard-first command palette. Summon, aim, pounce. Every command is just a file.',
    href: 'https://github.com/nebelhaus/pounce',
  },
  {
    name: 'nebelung',
    logo: '/logos/nebelung-accent.png',
    tagline: 'the colors',
    blurb:
      'a silver-mist Catppuccin variant, whiskered onto every app you own. Grey is the point.',
    href: 'https://github.com/nebelhaus/nebelung',
  },
  {
    name: 'trill',
    logo: '/logos/trill.png',
    tagline: 'the messages',
    blurb:
      'a fast, keyboard-first iMessage, SMS & RCS client. Reads chat.db read-only — it changes nothing.',
    href: 'https://github.com/nebelhaus/trill',
  },
];

// Nebelung neutral ramp + a few accents, for the swatch strip.
const swatches = [
  '#121212', '#191919', '#202020', '#343434', '#494949', '#5c5c5c',
  '#717171', '#858585', '#9a9a9a', '#aeaeae', '#c3c3c3', '#d7d7d7',
  '#f2c4e5', '#c9a8f1', '#f5b58e', '#9be0d5', '#abe1a6', '#8db4f3',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>nebelhaus — an opinionated macOS, raised in the fog</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="nebelhaus" />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content="https://nebelhaus.com/social/og.png" />
    <meta property="og:url" content="https://nebelhaus.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://nebelhaus.com/social/og.png" />
    <meta name="theme-color" content="#202020" />
  </head>
  <body>
    <div class="fog" aria-hidden="true"></div>

    <header class="nav">
      <a class="brand" href="/">
        <img src="/logos/nebelhaus-mark-fill.png" alt="" width="28" height="28" />
        <span>nebelhaus</span>
      </a>
      <nav class="nav-links">
        <a href="/start/what-is-nebelhaus/">Docs</a>
        <a href="/start/install/">Install</a>
        <a href="https://github.com/nebelhaus">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <p class="eyebrow">silver-grey · keyboard-first · reproducible · nix-native</p>
        <h1>An opinionated macOS,<br /><span class="fogtext">raised in the fog.</span></h1>
        <p class="lede">
          A small family of tools that turn a Mac into a quiet, keyboard-first,
          fog-grey workstation — arranged like a tiling Linux rig, but native to
          the grain of the Mac. One Nix flake raises the whole house.
        </p>

        <div class="install">
          <div class="install-row">
            <code id="install-cmd">{install}</code>
            <button id="copy" aria-label="Copy install command" title="Copy">
              <span class="copy-idle">Copy</span>
              <span class="copy-done">Copied ✓</span>
            </button>
          </div>
          <p class="install-note">
            Paste it into your terminal. It reads the rice's <code>bootstrap.sh</code>
            straight from GitHub — <a href="/start/install/">see exactly what it does</a>.
          </p>
        </div>

        <div class="cta">
          <a class="btn btn-primary" href="/start/what-is-nebelhaus/">Read the docs</a>
          <a class="btn btn-ghost" href="https://github.com/nebelhaus">View on GitHub</a>
        </div>

        <div class="swatches" aria-hidden="true">
          {swatches.map((c) => <span style={`background:${c}`}></span>)}
        </div>
      </section>

      <section class="family">
        <div class="section-head">
          <h2>Four rooms, one house</h2>
          <p>Each piece also stands on its own. Take the whole rice, or just the parts you like.</p>
        </div>
        <div class="family-grid">
          {
            family.map((r) => (
              <a class="room" href={r.href}>
                <img src={r.logo} alt={`${r.name} logo`} width="56" height="56" />
                <div class="room-name">
                  <strong>{r.name}</strong>
                  <span>{r.tagline}</span>
                </div>
                <p>{r.blurb}</p>
                <span class="room-link">Explore →</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="closer">
        <h2>Wipe it, and it stands again.</h2>
        <p>
          Everything above is described in text and pinned to an exact commit.
          The docs walk you from the one-liner to tuning every knob — and the
          house holds your hand throughout: a built-in cheatsheet on
          <code>⇪ /</code>, a <code>haus doctor</code> for anything that feels
          off, one-command rollback, and an installer that never deletes what
          it didn't create.
        </p>
        <div class="cta">
          <a class="btn btn-primary" href="/start/what-is-nebelhaus/">Get started</a>
          <a class="btn btn-ghost" href="/reference/keybindings/">Keybindings</a>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-inner">
        <span>🌫 nebelhaus · raised in the fog</span>
        <nav>
          <a href="/start/what-is-nebelhaus/">Docs</a>
          <a href="https://github.com/nebelhaus">GitHub</a>
          <a href="https://github.com/nebelhaus/nebelhaus/blob/main/LICENSE">MIT</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      const btn = document.getElementById('copy');
      const cmd = document.getElementById('install-cmd');
      btn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(cmd.textContent.trim());
          btn.classList.add('done');
          setTimeout(() => btn.classList.remove('done'), 1600);
        } catch (_) {
          /* clipboard blocked — no-op */
        }
      });
    </script>

    <style is:global>
      :root {
        --base: #202020;
        --mantle: #191919;
        --crust: #121212;
        --surface0: #343434;
        --surface1: #494949;
        --surface2: #5c5c5c;
        --text: #d7d7d7;
        --subtext0: #aeaeae;
        --overlay1: #858585;
        --mauve: #c9a8f1;
        --pink: #f2c4e5;
        --lavender: #b5bff8;
        --teal: #9be0d5;
        --green: #abe1a6;
        --font: ui-sans-serif, system-ui, -apple-system, 'SF Pro Text', 'Segoe UI',
          Roboto, Helvetica, Arial, sans-serif;
        --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Fira Code', Menlo,
          Consolas, monospace;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--base);
        color: var(--text);
        font-family: var(--font);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .fog {
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(60% 50% at 18% 0%, rgba(201, 168, 241, 0.16), transparent 70%),
          radial-gradient(50% 45% at 90% 8%, rgba(242, 196, 229, 0.10), transparent 70%),
          radial-gradient(70% 60% at 50% 100%, rgba(155, 224, 213, 0.06), transparent 70%),
          linear-gradient(180deg, #232323 0%, var(--base) 40%, var(--mantle) 100%);
      }

      a { color: var(--mauve); text-decoration: none; }
      a:hover { color: var(--lavender); }

      /* ---- nav ---- */
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1080px;
        margin: 0 auto;
        padding: 1.4rem 1.5rem;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--text);
        font-weight: 650;
        font-size: 1.05rem;
      }
      .brand img { border-radius: 7px; }
      .nav-links { display: flex; gap: 1.4rem; font-size: 0.95rem; }
      .nav-links a { color: var(--subtext0); }
      .nav-links a:hover { color: var(--text); }

      /* ---- hero ---- */
      main { max-width: 1080px; margin: 0 auto; padding: 0 1.5rem; }

      .hero {
        text-align: center;
        padding: 4.5rem 0 3rem;
      }
      .eyebrow {
        text-transform: lowercase;
        letter-spacing: 0.06em;
        color: var(--overlay1);
        font-size: 0.82rem;
        margin: 0 0 1.2rem;
      }
      .hero h1 {
        font-size: clamp(2.4rem, 6vw, 4.1rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        margin: 0 0 1.3rem;
        font-weight: 700;
      }
      .fogtext {
        background: linear-gradient(115deg, var(--text) 10%, var(--mauve) 55%, var(--pink) 95%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .lede {
        max-width: 640px;
        margin: 0 auto 2.2rem;
        color: var(--subtext0);
        font-size: 1.12rem;
      }

      /* ---- install one-liner ---- */
      .install { max-width: 640px; margin: 0 auto 1.8rem; }
      .install-row {
        display: flex;
        align-items: stretch;
        gap: 0.5rem;
        background: rgba(18, 18, 18, 0.72);
        border: 1px solid var(--surface0);
        border-radius: 12px;
        padding: 0.5rem 0.55rem 0.5rem 1rem;
        box-shadow: 0 20px 60px -30px rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(8px);
      }
      .install-row code {
        flex: 1;
        font-family: var(--mono);
        font-size: 0.98rem;
        color: var(--text);
        text-align: left;
        overflow-x: auto;
        white-space: nowrap;
        display: flex;
        align-items: center;
      }
      .install-row code::before { content: '$'; color: var(--mauve); margin-right: 0.7rem; }
      #copy {
        flex-shrink: 0;
        border: 1px solid var(--surface1);
        background: var(--surface0);
        color: var(--text);
        font-family: var(--font);
        font-size: 0.85rem;
        padding: 0 0.95rem;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
      }
      #copy:hover { background: var(--surface1); border-color: var(--surface2); }
      #copy .copy-done { display: none; color: var(--green); }
      #copy.done .copy-idle { display: none; }
      #copy.done .copy-done { display: inline; }
      .install-note { color: var(--overlay1); font-size: 0.85rem; margin: 0.75rem 0 0; }
      .install-note code { font-family: var(--mono); font-size: 0.8rem; color: var(--subtext0); }

      /* ---- buttons ---- */
      .cta { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.7rem 1.4rem;
        border-radius: 10px;
        font-weight: 550;
        font-size: 0.98rem;
        transition: transform 0.12s, background 0.15s, border-color 0.15s;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn-primary {
        background: linear-gradient(120deg, var(--mauve), var(--pink));
        color: #1a1220;
        box-shadow: 0 12px 30px -14px rgba(201, 168, 241, 0.7);
      }
      .btn-primary:hover { color: #1a1220; }
      .btn-ghost {
        border: 1px solid var(--surface1);
        color: var(--text);
        background: rgba(52, 52, 52, 0.35);
      }
      .btn-ghost:hover { color: var(--text); border-color: var(--surface2); }

      /* ---- swatch strip ---- */
      .swatches {
        display: flex;
        gap: 4px;
        justify-content: center;
        margin: 3rem auto 0;
        max-width: 460px;
        flex-wrap: wrap;
      }
      .swatches span {
        width: 20px;
        height: 20px;
        border-radius: 5px;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
      }

      /* ---- family ---- */
      .section-head { text-align: center; margin-bottom: 2.2rem; }
      .section-head h2 { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0 0 0.6rem; letter-spacing: -0.02em; }
      .section-head p { color: var(--subtext0); margin: 0; }
      .family { margin: 5rem 0; }
      .family-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.1rem;
      }
      @media (max-width: 640px) {
        .family-grid { grid-template-columns: 1fr; }
      }
      .room {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        background: rgba(25, 25, 25, 0.6);
        border: 1px solid var(--surface0);
        border-radius: 16px;
        padding: 1.6rem;
        color: var(--text);
        transition: border-color 0.2s, transform 0.2s, background 0.2s;
      }
      .room:hover { border-color: var(--mauve); transform: translateY(-3px); background: rgba(30, 30, 30, 0.8); }
      .room img { border-radius: 12px; }
      .room-name { display: flex; align-items: baseline; gap: 0.55rem; }
      .room-name strong { font-size: 1.2rem; }
      .room-name span { color: var(--overlay1); font-size: 0.85rem; }
      .room p { margin: 0; color: var(--subtext0); font-size: 0.95rem; flex: 1; }
      .room-link { color: var(--mauve); font-size: 0.9rem; font-weight: 550; }

      /* ---- closer ---- */
      .closer {
        text-align: center;
        margin: 6rem 0;
        padding: 3.5rem 1.5rem;
        border: 1px solid var(--surface0);
        border-radius: 20px;
        background:
          radial-gradient(60% 120% at 50% 0%, rgba(201, 168, 241, 0.1), transparent 70%),
          rgba(25, 25, 25, 0.5);
      }
      .closer h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 0 0 0.8rem; letter-spacing: -0.02em; }
      .closer p { color: var(--subtext0); max-width: 520px; margin: 0 auto 2rem; }

      /* ---- footer ---- */
      .foot { border-top: 1px solid var(--surface0); margin-top: 3rem; }
      .foot-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 1.8rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        color: var(--overlay1);
        font-size: 0.9rem;
      }
      .foot-inner nav { display: flex; gap: 1.3rem; }
      .foot-inner nav a { color: var(--subtext0); }

      @media (max-width: 560px) {
        .install-row code { font-size: 0.82rem; }
        .nav-links { gap: 1rem; }
      }
    </style>
  </body>
</html>
