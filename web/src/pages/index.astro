---
// nebelhaus.com — the landing page. Fully custom (not the Starlight layout).
// Pounce and Trill reuse the same nav, feature rail, cards, and panel language
// through ProductLanding.astro while keeping the rice's page a little fuller.
import FamilyNav from '../components/FamilyNav.astro';
const desc =
  'An opinionated macOS, raised in the fog. Silver-grey, keyboard-first, reproducible, Nix-native. One curl and one Nix flake raise the whole house.';
const install = 'curl -fsSL https://nebelhaus.com/init.sh | bash';
const productAccent = '#f2c4e5';

// One-time cache-bust for the logo images. The Instagram/Facebook in-app
// browsers cached broken/partial image entries during the "no CSS" era and don't
// reliably revalidate; bumping this query string hands them a fresh URL so the
// clean, cacheable response (see public/_headers) is fetched instead. Only bump
// this if you ever need to force-evict a cached logo — routine logo changes
// self-heal within the images' max-age.
const assetV = '2';
const bust = (path) => `${path}?v=${assetV}`;

const family = [
  {
    name: 'nebelhaus',
    logo: '/logos/nebelhaus.png',
    tagline: 'the rice',
    blurb:
      'nix-darwin modules for tiling, a status bar, the shell, and Touch ID sudo — the whole system as text.',
    href: 'https://github.com/nebelhaus/nebelhaus',
    accent: '#f2c4e5',
  },
  {
    name: 'pounce',
    logo: '/logos/pounce-peeking.png',
    tagline: 'the launcher',
    blurb:
      'a native, keyboard-first command palette. Summon, aim, pounce. Every command is just a file.',
    href: '/pounce/',
    accent: '#f5b58e',
  },
  {
    name: 'nebelung',
    logo: '/logos/nebelung-accent.png',
    tagline: 'the colors',
    blurb:
      'a silver-mist Catppuccin variant, whiskered onto every app you own. Grey is the point.',
    href: 'https://github.com/nebelhaus/nebelung',
    accent: '#c9a8f1',
  },
  {
    name: 'trill',
    logo: '/logos/trill.png',
    tagline: 'the messages',
    blurb:
      'a fast, keyboard-first iMessage, SMS & RCS client. Reads chat.db read-only — it changes nothing.',
    href: '/trill/',
    accent: '#8db4f3',
  },
];

const features = [
  {
    category: 'system',
    title: 'Fresh-Mac defaults',
    blurb:
      'Dock, Finder, keyboard, trackpad, fonts, Homebrew, and core tools are already declared.',
    accent: '#f2c4e5',
  },
  {
    category: 'windows',
    title: 'Tiling that sticks',
    blurb:
      'AeroSpace layout, hotkeys, boot agents, and a wake-time window re-sort come wired in.',
    accent: '#c9a8f1',
  },
  {
    category: 'pounce',
    title: 'Apps + actions',
    blurb:
      'Pounce puts installed apps and your own shell-script commands behind ⌘Space.',
    accent: '#f5b58e',
  },
  {
    category: 'pounce',
    title: 'Clipboard history',
    blurb:
      'Search recent copies and paste them back without adding another menu-bar utility.',
    accent: '#9be0d5',
  },
  {
    category: 'pounce',
    title: 'Quick answers',
    blurb:
      'Math, units, time zones, and optional currency conversion answer inside the palette.',
    accent: '#abe1a6',
  },
  {
    category: 'pounce',
    title: 'A real window switcher',
    blurb:
      '⌘Tab moves by recent window across workspaces; hold and type to fuzzy-filter.',
    accent: '#91dbe8',
  },
  {
    category: 'shell',
    title: 'Terminal, finished',
    blurb:
      'Ghostty, zellij, Helix, Yazi, Starship, bat, delta, fzf, and zoxide share one theme.',
    accent: '#8db4f3',
  },
  {
    category: 'security',
    title: 'Touch ID sudo',
    blurb:
      'Authenticate with a finger at the prompt — including from inside zellij or tmux.',
    accent: '#b5bff8',
  },
  {
    category: 'recovery',
    title: 'Doctor + rollback',
    blurb:
      'Inspect drift, diagnose common failures, or step back a complete system generation.',
    accent: '#f7e2b5',
  },
  {
    category: 'focus',
    title: 'One-key quiet',
    blurb:
      'Focus mode, optional Slack status, and your own shell hooks move together.',
    accent: '#efcece',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>nebelhaus — an opinionated macOS, raised in the fog</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="nebelhaus" />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content="https://nebelhaus.com/social/og.png" />
    <meta property="og:url" content="https://nebelhaus.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://nebelhaus.com/social/og.png" />
    <meta name="theme-color" content="#202020" />
  </head>
  <body data-product="nebelhaus" style={`--product-accent: ${productAccent}`}>
    <div class="fog" aria-hidden="true"></div>

    <FamilyNav active="nebelhaus" />

    <main>
      <section class="hero">
        <p class="eyebrow">silver-grey · keyboard-first · reproducible · nix-native</p>
        <h1>An opinionated macOS,<br /><span class="fogtext">raised in the fog.</span></h1>
        <p class="lede">One command. Your Mac, already sorted.</p>

        <div class="install">
          <div class="install-row">
            <code id="install-cmd" data-command={install} aria-label={install}>
              <span class="prompt">$</span>
              <span class="command">curl</span>
              <span class="flag">-fsSL</span>
              <span class="url">https://nebelhaus.com/init.sh</span>
              <span class="pipe">|</span>
              <span class="command">bash</span>
            </code>
            <button id="copy" aria-label="Copy install command" title="Copy">
              <span class="copy-idle">Copy</span>
              <span class="copy-done">Copied ✓</span>
            </button>
          </div>
          <p class="install-note">
            Paste it into your terminal. It reads the rice's <code>bootstrap.sh</code>
            straight from GitHub — <a href="/start/install/">see exactly what it does</a>.
          </p>
        </div>

        <div class="cta">
          <a class="btn btn-primary" href="/start/what-is-nebelhaus/">Read the docs</a>
          <a class="btn btn-ghost" href="https://github.com/nebelhaus">View on GitHub</a>
        </div>
      </section>

      <section class="family">
        <div class="section-head">
          <h2>Four rooms, one house</h2>
          <p>Each piece also stands on its own. Take the whole rice, or just the parts you like.</p>
        </div>
        <div class="family-grid">
          {
            family.map((room) => (
              <a class="room" href={room.href} style={`--accent: ${room.accent}`}>
                <img src={bust(room.logo)} alt={`${room.name} logo`} width="56" height="56" />
                <div class="room-name">
                  <strong>{room.name}</strong>
                  <span>{room.tagline}</span>
                </div>
                <p>{room.blurb}</p>
                <span class="room-link">Explore →</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="features" aria-labelledby="feature-title">
        <div class="feature-head">
          <div>
            <p class="section-label">included in the rice</p>
            <h2 id="feature-title">The useful bits are already here.</h2>
            <p>Things people usually rebuild one utility at a time.</p>
          </div>
          <div class="rail-controls" aria-label="Feature list controls">
            <button type="button" data-scroll="-1" aria-label="Previous features">←</button>
            <button type="button" data-scroll="1" aria-label="Next features">→</button>
          </div>
        </div>

        <div class="feature-rail" data-feature-rail tabindex="0">
          {
            features.map((feature, index) => (
              <article class="feature-card" style={`--accent: ${feature.accent}`}>
                <div class="feature-meta">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <span>{feature.category}</span>
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.blurb}</p>
              </article>
            ))
          }
        </div>
        <p class="swipe-note">drag, swipe, or use the arrows</p>
      </section>

      <section class="closer">
        <div class="panel-title" aria-hidden="true">
          <span class="status-dot"></span>
          <span>system.profile</span>
          <span class="status">reproducible</span>
        </div>
        <div class="closer-grid">
          <h2>The whole machine is the config.</h2>
          <div>
            <p>
              Tiling, launcher, shell, bar, defaults — raised from one flake,
              not a weekend of setup.
            </p>
            <div class="cta closer-cta">
              <a class="btn btn-primary" href="/start/install/">Get started</a>
              <a class="btn btn-ghost" href="https://github.com/nebelhaus/nebelhaus">
                See the source
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-inner">
        <span>🌫 nebelhaus · raised in the fog</span>
        <nav>
          <a href="/start/what-is-nebelhaus/">Docs</a>
          <a href="https://github.com/nebelhaus">GitHub</a>
          <a href="https://github.com/nebelhaus/nebelhaus/blob/main/LICENSE">MIT</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      const copyButton = document.getElementById('copy');
      const installCommand = document.getElementById('install-cmd')?.dataset.command;

      copyButton?.addEventListener('click', async () => {
        if (!installCommand) return;

        try {
          await navigator.clipboard.writeText(installCommand);
          copyButton.classList.add('done');
          setTimeout(() => copyButton.classList.remove('done'), 1600);
        } catch (_) {
          /* clipboard blocked — no-op */
        }
      });

      const rail = document.querySelector('[data-feature-rail]');
      document.querySelectorAll('[data-scroll]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!rail) return;
          const direction = Number(button.dataset.scroll);
          rail.scrollBy({ left: direction * rail.clientWidth * 0.72, behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      :root {
        --base: #202020;
        --mantle: #191919;
        --crust: #121212;
        --surface0: #343434;
        --surface1: #494949;
        --surface2: #5c5c5c;
        --text: #d7d7d7;
        --subtext1: #c3c3c3;
        --subtext0: #aeaeae;
        --overlay1: #858585;
        --pink: #f2c4e5;
        --mauve: #c9a8f1;
        --peach: #f5b58e;
        --teal: #9be0d5;
        --green: #abe1a6;
        --blue: #8db4f3;
        --lavender: #b5bff8;
        --font: ui-sans-serif, system-ui, -apple-system, 'SF Pro Text', 'Segoe UI',
          Roboto, Helvetica, Arial, sans-serif;
        --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Fira Code', Menlo,
          Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--base);
        color: var(--text);
        font-family: var(--font);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .fog {
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(65% 36% at 50% -8%, rgba(201, 168, 241, 0.09), transparent 75%),
          var(--base);
      }

      ::selection {
        background: var(--pink);
        color: var(--crust);
      }

      a {
        color: var(--mauve);
        text-decoration: none;
      }

      a:hover {
        color: var(--lavender);
      }

      /* ---- reusable product nav ---- */
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1080px;
        margin: 0 auto;
        padding: 1.4rem 1.5rem;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--text);
        font-weight: 650;
        font-size: 1.05rem;
      }

      .brand:hover {
        color: var(--text);
      }

      .brand span {
        background: none;
        color: var(--text);
        -webkit-text-fill-color: currentColor;
      }

      .brand img {
        border-radius: 7px;
      }

      .nav-links {
        display: flex;
        gap: 1.4rem;
        font-size: 0.95rem;
      }

      .nav-links a {
        color: var(--subtext0);
      }

      .nav-links a:hover {
        color: var(--text);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ---- hero ---- */
      .hero {
        text-align: center;
        padding: 4.5rem 0 3rem;
      }

      .eyebrow,
      .section-label {
        margin: 0 0 1.2rem;
        color: var(--overlay1);
        font-family: var(--mono);
        font-size: 0.78rem;
        letter-spacing: 0.055em;
        text-transform: lowercase;
      }

      .hero h1 {
        margin: 0 0 1rem;
        font-size: clamp(2.4rem, 6vw, 4.1rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.05;
      }

      .fogtext {
        color: var(--product-accent);
      }

      .lede {
        margin: 0 auto 2rem;
        color: var(--subtext0);
        font-family: var(--mono);
        font-size: 0.98rem;
      }

      /* ---- terminal install line ---- */
      .install {
        max-width: 680px;
        margin: 0 auto 1.8rem;
      }

      .install-row {
        display: flex;
        align-items: stretch;
        gap: 0.5rem;
        padding: 0.5rem 0.55rem 0.5rem 1rem;
        background: var(--crust);
        border: 1px solid var(--surface0);
        border-radius: 10px;
      }

      .install-row code {
        display: flex;
        flex: 1;
        min-width: 0;
        align-items: center;
        gap: 0.55em;
        overflow-x: auto;
        color: var(--text);
        font-family: var(--mono);
        font-size: 0.95rem;
        text-align: left;
        white-space: nowrap;
      }

      .install-row .prompt {
        margin-right: 0.2rem;
        color: var(--mauve);
      }

      .install-row .command {
        color: var(--pink);
      }

      .install-row .flag {
        color: var(--peach);
      }

      .install-row .url {
        color: var(--teal);
      }

      .install-row .pipe {
        color: var(--overlay1);
      }

      #copy {
        flex-shrink: 0;
        padding: 0 0.95rem;
        background: var(--surface0);
        border: 1px solid var(--surface1);
        border-radius: 7px;
        color: var(--text);
        cursor: pointer;
        font-family: var(--font);
        font-size: 0.85rem;
      }

      #copy:hover {
        background: var(--surface1);
        border-color: var(--surface2);
      }

      #copy .copy-done {
        display: none;
        color: var(--green);
      }

      #copy.done .copy-idle {
        display: none;
      }

      #copy.done .copy-done {
        display: inline;
      }

      .install-note {
        margin: 0.75rem 0 0;
        color: var(--overlay1);
        font-size: 0.85rem;
      }

      .install-note code {
        color: var(--subtext0);
        font-family: var(--mono);
        font-size: 0.8rem;
      }

      /* ---- buttons ---- */
      .cta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.8rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.68rem 1.35rem;
        border: 1px solid transparent;
        border-radius: 8px;
        font-size: 0.96rem;
        font-weight: 580;
        transition: background 0.15s, border-color 0.15s;
      }

      .btn-primary {
        background: var(--product-accent);
        color: var(--crust);
      }

      .btn-primary:hover {
        background: #f6d0eb;
        color: var(--crust);
      }

      .btn-ghost {
        background: var(--mantle);
        border-color: var(--surface1);
        color: var(--text);
      }

      .btn-ghost:hover {
        border-color: var(--surface2);
        color: var(--text);
      }

      /* ---- family ---- */
      .section-head {
        margin-bottom: 2.2rem;
        text-align: center;
      }

      .section-head h2,
      .feature-head h2,
      .closer h2 {
        margin: 0 0 0.6rem;
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        letter-spacing: -0.025em;
        line-height: 1.12;
      }

      .section-head p,
      .feature-head > div > p:last-child {
        margin: 0;
        color: var(--subtext0);
      }

      .family {
        margin: 5rem 0 6rem;
      }

      .family-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .room {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        padding: 1.6rem;
        background: var(--mantle);
        border: 1px solid var(--surface0);
        border-top: 3px solid var(--accent);
        border-radius: 11px;
        color: var(--text);
        transition: border-color 0.15s, background 0.15s;
      }

      .room:hover {
        background: #1c1c1c;
        border-color: var(--accent);
        color: var(--text);
      }

      .room img {
        border-radius: 10px;
      }

      .room-name {
        display: flex;
        align-items: baseline;
        gap: 0.55rem;
      }

      .room-name strong {
        font-size: 1.2rem;
      }

      .room-name span {
        color: var(--overlay1);
        font-size: 0.85rem;
      }

      .room p {
        flex: 1;
        margin: 0;
        color: var(--subtext0);
        font-size: 0.95rem;
      }

      .room-link {
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
      }

      /* ---- horizontal feature rail ---- */
      .features {
        margin: 0 0 6rem;
      }

      .feature-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 1.5rem;
      }

      .feature-head .section-label {
        margin-bottom: 0.65rem;
        color: var(--pink);
      }

      .feature-head h2 {
        font-size: clamp(1.8rem, 4vw, 2.7rem);
      }

      .rail-controls {
        display: flex;
        flex-shrink: 0;
        gap: 0.45rem;
      }

      .rail-controls button {
        width: 2.7rem;
        height: 2.7rem;
        background: var(--mantle);
        border: 1px solid var(--surface1);
        border-radius: 7px;
        color: var(--text);
        cursor: pointer;
        font-family: var(--mono);
        font-size: 1rem;
      }

      .rail-controls button:hover {
        background: var(--surface0);
        border-color: var(--surface2);
      }

      .feature-rail {
        display: flex;
        gap: 0.8rem;
        padding: 0 0 0.7rem;
        overflow-x: auto;
        overscroll-behavior-x: contain;
        scroll-behavior: smooth;
        scroll-snap-type: x mandatory;
        scrollbar-color: var(--surface2) var(--mantle);
        scrollbar-width: thin;
      }

      .feature-card {
        display: flex;
        flex: 0 0 250px;
        flex-direction: column;
        min-height: 220px;
        padding: 1.15rem;
        background: var(--mantle);
        border: 1px solid var(--surface0);
        border-top: 3px solid var(--accent);
        border-radius: 9px;
        scroll-snap-align: start;
      }

      .feature-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: var(--accent);
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .feature-card h3 {
        margin: auto 0 0.55rem;
        color: var(--text);
        font-size: 1.16rem;
        letter-spacing: -0.015em;
        line-height: 1.2;
      }

      .feature-card p {
        margin: 0;
        color: var(--subtext0);
        font-size: 0.88rem;
        line-height: 1.5;
      }

      .swipe-note {
        margin: 0.65rem 0 0;
        color: var(--overlay1);
        font-family: var(--mono);
        font-size: 0.72rem;
        text-align: right;
      }

      /* ---- closer panel ---- */
      .closer {
        margin: 6rem 0;
        background: var(--mantle);
        border: 1px solid var(--surface0);
        border-radius: 11px;
      }

      .panel-title {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 0.9rem;
        border-bottom: 1px solid var(--surface0);
        color: var(--overlay1);
        font-family: var(--mono);
        font-size: 0.72rem;
      }

      .status-dot {
        width: 0.5rem;
        height: 0.5rem;
        background: var(--green);
        border-radius: 50%;
      }

      .panel-title .status {
        margin-left: auto;
        color: var(--green);
      }

      .closer-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        align-items: center;
        gap: 3rem;
        padding: 2.5rem;
      }

      .closer h2 {
        margin: 0;
        font-size: clamp(2rem, 4.6vw, 3.2rem);
      }

      .closer-grid p {
        margin: 0 0 1.5rem;
        color: var(--subtext0);
      }

      .closer-cta {
        justify-content: flex-start;
      }

      /* ---- footer ---- */
      .foot {
        margin-top: 3rem;
        border-top: 1px solid var(--surface0);
      }

      .foot-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        max-width: 1080px;
        margin: 0 auto;
        padding: 1.8rem 1.5rem;
        gap: 1rem;
        color: var(--overlay1);
        font-size: 0.9rem;
      }

      .foot-inner nav {
        display: flex;
        gap: 1.3rem;
      }

      .foot-inner nav a {
        color: var(--subtext0);
      }

      @media (max-width: 640px) {
        .nav {
          padding: 1.15rem 1rem;
        }

        .nav-links {
          gap: 0.9rem;
          font-size: 0.9rem;
        }

        main {
          padding: 0 1rem;
        }

        .hero {
          padding: 3.5rem 0 2rem;
        }

        .eyebrow {
          margin-bottom: 1rem;
          font-size: 0.7rem;
        }

        .install-row {
          padding-left: 0.8rem;
        }

        .install-row code {
