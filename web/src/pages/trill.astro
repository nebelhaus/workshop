---
import ProductLanding from '../layouts/ProductLanding.astro';

const features = [
  {
    category: 'messages',
    title: 'Read everything',
    blurb:
      'iMessage, SMS, RCS, tapbacks, replies, edits, attachments, groups, and unread state in one native view.',
    accent: '#8db4f3',
  },
  {
    category: 'search',
    title: 'Search like you mean it',
    blurb:
      'Find any message with filters for person, group, link, image, date, or unread state.',
    accent: '#b5bff8',
  },
  {
    category: 'library',
    title: 'Every shared thing',
    blurb:
      'Browse every image, link, file, and saved message across all conversations, then jump to its source.',
    accent: '#9be0d5',
  },
  {
    category: 'triage',
    title: 'Know who needs a reply',
    blurb:
      'Filter to conversations they last answered, then snooze, archive, pin, tag, or file them locally.',
    accent: '#f7e2b5',
  },
  {
    category: 'compose',
    title: 'Write without friction',
    blurb:
      'Persistent drafts, snippets, slash commands, contact autocomplete, attachments, and five-second undo send.',
    accent: '#f2c4e5',
  },
  {
    category: 'export',
    title: 'Your history is yours',
    blurb:
      'Export one thread or the whole corpus as Markdown, text, or HTML — clean and ready to use elsewhere.',
    accent: '#c9a8f1',
  },
];
---

<ProductLanding
  product="trill"
  accent="#8db4f3"
  accentHover="#a8c7f7"
  logo="/logos/trill.png"
  eyebrow="native · keyboard-first · local-first · macos"
  titleLead="Your Messages,"
  titleAccent="native."
  lede="A fast, flat iMessage, SMS & RCS client. Your real conversations, without the clutter."
  description="Trill is a native, keyboard-first iMessage, SMS and RCS client for macOS. It reads chat.db read-only and installs standalone with Homebrew."
  install="brew install --cask nebelhaus/tap/trill"
  installMarkup={{
    command: 'brew install',
    flag: '--cask',
    formula: 'nebelhaus/tap/trill',
  }}
  standaloneCopy="This adds only Trill.app to your Mac. It does not install Nix, change Messages, or configure the rest of nebelhaus."
  riceCopy="Trill is enabled by default in nebelhaus, so the full rice already brings it along."
  riceHref="/start/what-is-nebelhaus/"
  guideHref="/guides/trill/"
  repoHref="https://github.com/nebelhaus/trill"
  featuresLabel="messages, shaped for triage"
  featuresTitle="Everything Messages forgot."
  featuresCopy="Search, organize, compose, and export from a fast native client that stays close to the keyboard."
  features={features}
  closerStatus="chat.db read-only"
  closerTitle="It reads everything. It changes nothing."
  closerCopy="Every chat.db connection is read-only. Sending goes through Messages.app, organization stays in Trill's own local database, and there is no relay or cloud service."
  closerPrimaryLabel="Read the trust story"
  closerPrimaryHref="/guides/trill/#honest-scope"
/>
