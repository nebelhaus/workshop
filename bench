#!/usr/bin/env bash
# bench — the workshop CLI for the nebelhaus family.
#
# The family is a chain of flakes, each pinning the one before it:
#
#   nebelung (theme) ──> pounce (palette app) ──> nebelhaus (the rice) ──> ~/.config/nix (your machine)
#                └────────────────────────────────────┘
#
# Editing upstream means nothing until the downstream locks catch up. This
# script exists so you never have to remember that dance:
#
#   bench status    where is everything? (git state, lock edges, agent worktrees)
#   bench try       build YOUR machine against the LOCAL checkouts — no pushes
#   bench try switch    …and activate it (still no pushes; prod untouched)
#   bench ship      push everything in dependency order, rippling lock updates
#   bench rebuild   a plain, pinned rebuild of your machine (the normal day)
#   bench pull      fast-forward every repo
#   bench clone     fetch any family repo missing from this directory
#   bench release   tag v<version> (read from the repo, never typed) — CI then
#                  publishes the GitHub release and bumps the Homebrew tap
#
# Rule of thumb: hack freely, `bench try` until happy, commit, `bench ship`.
#
# Agent worktrees: Claude Code sessions spawn into git worktrees of the family
# repos (branch `worktree-*`), so parallel agents never fight over a checkout's
# branch. `bench try` is worktree-aware — run it from inside a worktree and that
# repo's override points at the WORKTREE instead of the main checkout, so an
# agent can verify its own branch builds. `bench try switch` refuses from a
# worktree (only main-checkout code gets activated); `bench status` lists agent
# worktrees and unmerged agent branches; `bench ship` warns about them.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONSUMER="${HAUS_CONSUMER:-$HOME/.config/nix}"

# Dependency order matters: upstream first, so lock bumps can see pushed revs.
FAMILY=(nebelung pounce nebelhaus)
GH_ORG="nebelhaus"

say()  { printf '\033[38;5;103m🌫  %s\033[0m\n' "$*"; }
warn() { printf '\033[38;5;179m⚠  %s\033[0m\n' "$*"; }
die()  { printf '\033[38;5;167m✗  %s\033[0m\n' "$*" >&2; exit 1; }

repo_dir() { # repo_dir <name> — family repos live here; the consumer elsewhere
  if [ "$1" = "consumer" ]; then echo "$CONSUMER"; else echo "$ROOT/$1"; fi
}

head_rev() { git -C "$(repo_dir "$1")" rev-parse HEAD 2>/dev/null || echo "?"; }

locked_rev() { # locked_rev <repo> <input> — what rev <repo>'s flake.lock pins <input> at
  python3 - "$(repo_dir "$1")/flake.lock" "$2" <<'EOF'
import json, sys
try:
    lock = json.load(open(sys.argv[1]))
    print(lock["nodes"][sys.argv[2]]["locked"]["rev"])
except Exception:
    print("?")
EOF
}

# The lock edges of the family graph: "<consumer-repo> <input-name> <source-repo>"
EDGES=(
  "pounce nebelung nebelung"
  "nebelhaus nebelung nebelung"
  "nebelhaus pounce pounce"
  "consumer nebelhaus nebelhaus"
)

host_name() { # the darwinConfiguration to build in the consumer flake
  if [ -n "${HAUS_HOST:-}" ]; then echo "$HAUS_HOST"; return; fi
  nix eval --json "$CONSUMER#darwinConfigurations" --apply builtins.attrNames 2>/dev/null \
    | python3 -c 'import json,sys; print(json.load(sys.stdin)[0])' 2>/dev/null \
    || hostname -s
}

# If we're running from inside a LINKED worktree of a family repo (a Claude
# agent's isolated checkout), note which repo and where. Works wherever the
# worktree physically lives: --git-common-dir always points at the main
# checkout's .git, and a linked worktree is exactly "toplevel != main".
WT_REPO="" WT_PATH=""
detect_worktree() {
  local top common main name
  top="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0
  common="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 0
  main="$(dirname "$common")"
  [ "$top" = "$main" ] && return 0
  for name in "${FAMILY[@]}"; do
    if [ "$main" = "$ROOT/$name" ]; then WT_REPO="$name" WT_PATH="$top"; return 0; fi
  done
}

local_src() { # local_src <repo> — the checkout to build against (worktree-aware)
  if [ "$1" = "$WT_REPO" ]; then echo "$WT_PATH"; else echo "$ROOT/$1"; fi
}

overrides() { # every family input redirected at the local checkouts
  echo "--override-input nebelhaus path:$(local_src nebelhaus) \
        --override-input nebelhaus/nebelung path:$(local_src nebelung) \
        --override-input nebelhaus/pounce path:$(local_src pounce)"
}

# Agent worktree bookkeeping, shared by status + ship.
list_worktrees() { # list_worktrees <repo> — linked worktree paths, one per line
  git -C "$(repo_dir "$1")" worktree list --porcelain 2>/dev/null \
    | awk '$1 == "worktree" { print $2 }' | tail -n +2
}
unmerged_agent_branches() { # worktree-* branches not merged into the current HEAD
  git -C "$(repo_dir "$1")" branch --list 'worktree-*' --no-merged HEAD \
    --format='%(refname:short)' 2>/dev/null
}

cmd_status() {
  say "repos"
  printf '  %-12s %-8s %-7s %s\n' "repo" "branch" "dirty" "vs origin"
  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || { printf '  %-12s (missing — bench clone)\n' "$name"; continue; }
    local branch dirty ahead behind
    branch="$(git -C "$dir" branch --show-current)"
    dirty="$(git -C "$dir" status --porcelain | wc -l | tr -d ' ')"
    [ "$dirty" = "0" ] && dirty="·" || dirty="${dirty} files"
    git -C "$dir" fetch -q 2>/dev/null || true
    ahead="$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo '?')"
    behind="$(git -C "$dir" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo '?')"
    printf '  %-12s %-8s %-7s ↑%s ↓%s\n' "$name" "$branch" "$dirty" "$ahead" "$behind"
  done

  # Agent worktrees + their branches — only speak up if any exist.
  local wt_lines=""
  for name in "${FAMILY[@]}"; do
    local wt branch dirty
    while IFS= read -r wt; do
      [ -n "$wt" ] || continue
      branch="$(git -C "$wt" branch --show-current 2>/dev/null || echo '?')"
      dirty="$([ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ] && echo 'dirty' || echo '·')"
      wt_lines+="$(printf '  %-12s %-24s %-6s %s' "$name" "$branch" "$dirty" "$wt")"$'\n'
    done <<<"$(list_worktrees "$name")"
    local b
    for b in $(unmerged_agent_branches "$name"); do
      # branches whose worktree is gone but whose commits aren't merged yet
      if ! git -C "$(repo_dir "$name")" worktree list --porcelain | grep -q "branch refs/heads/$b"; then
        wt_lines+="$(printf '  %-12s %-24s %-6s %s' "$name" "$b" "·" "(no worktree — merge or delete the branch)")"$'\n'
      fi
    done
  done
  if [ -n "$wt_lines" ]; then
    echo
    say "agent worktrees (isolated Claude checkouts; merge into the main checkout when done)"
    printf '  %-12s %-24s %-6s %s\n' "repo" "branch" "dirty" "where"
    printf '%s' "$wt_lines"
  fi

  echo
  say "lock edges (is anyone consuming an old version of anyone?)"
  local stale=0
  for edge in "${EDGES[@]}"; do
    read -r holder input source <<<"$edge"
    local want have label
    want="$(head_rev "$source")"
    have="$(locked_rev "$holder" "$input")"
    label="$holder → $input"
    [ "$holder" = "consumer" ] && label="you → $input"
    if [ "$have" = "$want" ]; then
      printf '  ✓ %-22s current (%s)\n' "$label" "${have:0:7}"
    else
      printf '  ⚠ %-22s STALE: locked %s, local %s\n' "$label" "${have:0:7}" "${want:0:7}"
      stale=1
    fi
  done
  echo
  if [ "$stale" = "1" ]; then
    warn "stale edges above. If the upstream work is committed: bench ship."
    warn "To test it on this machine without pushing anything: bench try"
  else
    say "everything is current. The fog is even."
  fi
}

cmd_try() {
  local host; host="$(host_name)"
  detect_worktree
  if [ -n "$WT_REPO" ]; then
    if [ "${1:-}" = "switch" ]; then
      die "refusing to switch from an agent worktree of $WT_REPO — only the main checkouts get activated. Merge the branch, then try/switch from there."
    fi
    say "you're in an agent worktree — overriding $WT_REPO with $WT_PATH"
  fi
  say "building $host against the LOCAL checkouts (uncommitted edits included)…"
  # shellcheck disable=SC2046
  (cd "$CONSUMER" && nix build ".#darwinConfigurations.$host.system" $(overrides))
  say "build OK — nothing pushed, nothing activated."
  if [ "${1:-}" = "switch" ]; then
    say "switching (this activates the LOCAL build on this machine)…"
    # shellcheck disable=SC2046
    (cd "$CONSUMER" && sudo ./result/sw/bin/darwin-rebuild switch --flake ".#$host" $(overrides))
    warn "you are now running unpushed code. When happy: commit + bench ship,"
    warn "so a plain rebuild reproduces what you're running."
  else
    say "to activate it too: bench try switch"
  fi
}

cmd_ship() {
  # Walk the chain upstream→downstream. For each repo: refuse dirty trees
  # (your commits are yours to write), bump any stale family locks, push.
  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue
    if [ -n "$(git -C "$dir" status --porcelain)" ]; then
      git -C "$dir" status --short
      die "$name has uncommitted changes — commit (or stash) them first, then re-run bench ship."
    fi
  done

  # Agent branches never block a ship (main is main), but don't let them rot silently.
  for name in "${FAMILY[@]}"; do
    local unmerged; unmerged="$(unmerged_agent_branches "$name" | tr '\n' ' ')"
    if [ -n "${unmerged// /}" ]; then
      warn "$name has unmerged agent branches (not shipping them): $unmerged"
    fi
  done

  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue

    # Bump this repo's locks for any upstream family input that moved.
    local bumped=()
    for edge in "${EDGES[@]}"; do
      read -r holder input source <<<"$edge"
      [ "$holder" = "$name" ] || continue
      if [ "$(locked_rev "$holder" "$input")" != "$(head_rev "$source")" ]; then
        say "$name: updating lock for ${input}…"
        (cd "$dir" && nix flake update "$input")
        bumped+=("$input")
      fi
    done
    if [ "${#bumped[@]}" -gt 0 ]; then
      (cd "$dir" && git add flake.lock && git commit -m "Update flake inputs (${bumped[*]})")
    fi

    # Push if there's anywhere to push to and anything to push.
    if git -C "$dir" rev-parse '@{u}' >/dev/null 2>&1; then
      local ahead; ahead="$(git -C "$dir" rev-list --count '@{u}..HEAD')"
      if [ "$ahead" != "0" ]; then
        say "$name: pushing $ahead commit(s)…"
        git -C "$dir" push
      fi
    fi
  done

  say "shipped. Apply it to this machine with: bench rebuild"
}

# ── Claude Code worktree hooks ──────────────────────────────────────────────
# Wired into ~/.claude/settings.json as WorktreeCreate/WorktreeRemove hooks, so
# `claude --worktree` (the zellij Ctrl-Alt-c bind) creates its isolated checkout
# HERE instead of inside the repo (.claude/worktrees/ would pollute `bench try`'s
# path: overrides and dirty every tree). Layout: ~/.cache/claude-worktrees/
# <repo-basename>/<name>, branch worktree-<name>, branched from LOCAL HEAD (in
# this house local is usually ahead of origin). Works for any repo, not just
# the family. Contract (see Claude Code hooks docs): JSON on stdin; wt-create
# prints the new worktree path on stdout, everything else goes to stderr.

WT_BASE="$HOME/.cache/claude-worktrees"

# The payload's key names have drifted across Claude Code versions (docs say
# worktree_name/base_path; 2.1.x sends name/cwd) — accept either, first hit wins.
hook_field() { # hook_field <json> <key>… — first key present in the payload
  local json="$1"; shift
  python3 -c '
import json, sys
d = json.load(sys.stdin)
for k in sys.argv[1:]:
    if k in d:
        print(d[k]); break
else:
    print(f"hook payload has none of {sys.argv[1:]}: {d}", file=sys.stderr); sys.exit(1)
' "$@" <<<"$json"
}

cmd_wt_create() {
  local json name base dir
  json="$(cat)"
  name="$(hook_field "$json" name worktree_name)"
  base="$(hook_field "$json" base_path cwd)"
  dir="$WT_BASE/$(basename "$base")/$name"
  git -C "$base" worktree add -b "worktree-$name" "$dir" HEAD >&2
  echo "$dir"
}

cmd_wt_remove() {
  local json dir main branch
  json="$(cat)"
  dir="$(hook_field "$json" worktree_path path)"
  main="$(dirname "$(git -C "$dir" rev-parse --path-format=absolute --git-common-dir)")"
  branch="$(git -C "$dir" branch --show-current 2>/dev/null || true)"
  git -C "$main" worktree remove "$dir" 2>/dev/null \
    || git -C "$main" worktree remove --force "$dir"
  # The branch is how unmerged work survives pane-close; only reap it once merged
  # (-d refuses otherwise, which is exactly the safety we want — bench status will
  # keep nagging about the leftover until it's merged or deleted by hand).
  if [ -n "$branch" ]; then
    git -C "$main" branch -d "$branch" >/dev/null 2>&1 || true
  fi
}

cmd_rebuild() {
  local host; host="$(host_name)"
  say "pinned rebuild of $host from ${CONSUMER}…"
  (cd "$CONSUMER" \
    && nix build ".#darwinConfigurations.$host.system" \
    && sudo ./result/sw/bin/darwin-rebuild switch --flake ".#$host")
  say "the house stands."
}

cmd_pull() {
  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue
    say "pulling ${name}…"
    git -C "$dir" pull --ff-only || warn "$name: couldn't fast-forward; resolve by hand"
  done
}

version_file() { # version_file <repo> — WHERE a releasable repo's version lives
  case "$1" in
    pounce)    echo "$(repo_dir "$1")/pkgs/pounce/default.nix" ;;
    nebelhaus) echo "$(repo_dir "$1")/VERSION" ;;
    *) return 1 ;;
  esac
}

read_version() { # read_version <repo> — the version string that repo tags at
  local f; f="$(version_file "$1")" || return 1
  case "$1" in
    pounce)    sed -n 's/^ *version = "\([^"]*\)";.*/\1/p' "$f" | head -1 ;;
    nebelhaus) tr -d '[:space:]' < "$f" 2>/dev/null ;;
  esac
}

cmd_release() {
  # Cut a release: tag v<version> — read from the repo, never typed, so the
  # tag can't drift from what the code says (CI double-checks anyway). The
  # tag push is the button; CI does the rest: GitHub release + source tarball
  # + a version bump in homebrew-tap (which is CI-owned — never hand-bump it).
  # Division of labor: commits are yours, lock bumps are ship's, tags are
  # release's, formula bumps are CI's.
  local name="${1:-}"
  [ -n "$name" ] || die "usage: bench release <repo>   (releasable: pounce, nebelhaus)"

  local dir; dir="$(repo_dir "$name")"
  [ -d "$dir/.git" ] || die "$name is not cloned here — bench clone"
  [ -z "$(git -C "$dir" status --porcelain)" ] \
    || die "$name is dirty — commit (and bench ship) first"
  git -C "$dir" fetch -q --tags 2>/dev/null || true
  local ahead; ahead="$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo '?')"
  [ "$ahead" = "0" ] || die "$name has unpushed commits — bench ship first, then release"

  # Each releasable repo names its own version source (never typed, so the tag
  # can't drift from the code — CI double-checks on the tag).
  local verfile version
  verfile="$(version_file "$name")" \
    || die "bench release doesn't know '$name' yet (releasable: pounce, nebelhaus)"
  version="$(read_version "$name")"
  [ -n "$version" ] || die "couldn't read a version for $name"
  local tag="v$version"
  git -C "$dir" rev-parse -q --verify "refs/tags/$tag" >/dev/null \
    && die "$name $tag already exists — bump the version in $verfile first"

  say "releasing $name $tag — pushing the tag; CI takes it from here…"
  git -C "$dir" tag -a "$tag" -m "$name $version"
  git -C "$dir" push origin "$tag"
  say "watch it: https://github.com/$GH_ORG/$name/actions  (release → tap bump)"
}

cmd_clone() {
  for name in "${FAMILY[@]}" org-profile homebrew-tap; do
    local repo="$name"
    [ "$name" = "org-profile" ] && repo=".github"
    if [ -d "$ROOT/$name/.git" ]; then
      say "$name already here"
    else
      say "cloning ${name}…"
      git clone "https://github.com/$GH_ORG/$repo.git" "$ROOT/$name"
    fi
  done
}

# When sourced with HAUS_LIB=1 (the bats test harness), stop here: the caller
# just wants the functions above, not to dispatch a command.
if [ "${HAUS_LIB:-}" != "1" ]; then
case "${1:-status}" in
  status)  cmd_status ;;
  try)     cmd_try "${2:-}" ;;
  ship)    cmd_ship ;;
  rebuild) cmd_rebuild ;;
  pull)    cmd_pull ;;
  clone)   cmd_clone ;;
  release) cmd_release "${2:-}" ;;
  # plumbing: Claude Code WorktreeCreate/WorktreeRemove hooks (JSON on stdin)
  wt-create) cmd_wt_create ;;
  wt-remove) cmd_wt_remove ;;
  *)       sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'; exit 1 ;;
esac
fi
