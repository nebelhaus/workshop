#!/usr/bin/env bash
# bench — the workshop CLI for the nebelhaus family.
#
# The family is a chain of flakes, each pinning the one before it:
#
#   nebelung (theme) ──> pounce (palette app) ──> nebelhaus (the rice) ──> ~/.config/nix (your machine)
#                └────────────────────────────────────┘
#
# Editing upstream means nothing until the downstream locks catch up. This
# script exists so you never have to remember that dance:
#
#   bench status    where is everything? (git state, lock edges, release edges,
#                  agent worktrees)
#   bench try       build YOUR machine against the LOCAL checkouts — no pushes
#   bench try switch    …and activate it (still no pushes; prod untouched)
#   bench try-batch [switch] [repo…]   build (or activate) EVERY open PR's
#                  branch together on ONE throwaway integration tree per repo —
#                  feel-test the whole review queue in a single rebuild, main
#                  untouched, then merge only the PRs that pass
#   bench ship      push everything in dependency order, rippling lock updates
#   bench rebuild   a plain, pinned rebuild of your machine (the normal day)
#   bench pull      fast-forward every repo
#   bench clone     fetch any family repo missing from this directory
#   bench docs-since   commits in every repo since the docs were last
#                  reconciled (--mark records new watermarks) — the input
#                  to the daily /docs-sync sweep
#   bench release   stamp today's date as the version (YYYY.MM.DD, -N on a
#                  same-day repeat) and tag it — CI then publishes the GitHub
#                  release and bumps the Homebrew tap
#
# Rule of thumb: hack freely, `bench try` until happy, commit, `bench ship`.
#
# Agent worktrees: Claude Code sessions spawn into git worktrees of the family
# repos (branch `worktree-*`), so parallel agents never fight over a checkout's
# branch. `bench try` is worktree-aware — run it from inside a worktree and that
# repo's override points at the WORKTREE instead of the main checkout, so an
# agent can verify its own branch builds. `bench try switch` refuses from a
# worktree (only main-checkout code gets activated); `bench status` lists agent
# worktrees and unmerged agent branches; `bench ship` warns about them.
set -euo pipefail

# ROOT is the workshop MAIN checkout (~/code/nebelhaus) — the dir holding the
# family repos as subdirs. Derive it from the script's git-common-dir, NOT just
# dirname(BASH_SOURCE): a workshop *worktree* checks out its own copy of this
# script, so dirname would point at the worktree (which has NO child repos),
# silently breaking status/ship (an unguarded `git -C <missing>` under `set -e`
# → exit 128, no output). --git-common-dir resolves to the MAIN checkout's .git
# from any linked worktree, so ROOT stays correct however bench was invoked.
# Fall back to the script dir if git can't answer (run outside any checkout).
_bench_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_bench_common="$(git -C "$_bench_dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
if [ -n "$_bench_common" ]; then ROOT="$(dirname "$_bench_common")"; else ROOT="$_bench_dir"; fi
CONSUMER="${HAUS_CONSUMER:-$HOME/.config/nix}"

# Dependency order matters: upstream first, so lock bumps can see pushed revs.
# trill is a leaf: released to brew (a cask), but NOT a flake input of the rice
# (the rice installs it via Homebrew), so it has no EDGES and no override.
FAMILY=(nebelung pounce trill nebelhaus)
GH_ORG="nebelhaus"

# The family repos that are flake INPUTS of the rice, so `overrides()` can point
# them at a local checkout. trill is deliberately absent: it's a brew leaf, not a
# flake input, so there's nothing to override — bench try-batch skips it.
OVERRIDABLE=(nebelung pounce nebelhaus)

# bench try-batch's scratch state. Global (not local to cmd_try_batch) so the
# EXIT trap can still see it: an EXIT trap fires after the function has returned,
# by which point any `local` it captured is already out of scope and empty.
# -gA (not just -A): declare -A inside a function makes the array function-local,
# and bench is *sourced* into a function by the bats harness — so without -g the
# global vanishes and local_src's ${BATCH_SRC[…]:-} tries to read an unbound var.
declare -gA BATCH_SRC=()  # repo → integration-worktree checkout it should build against
BATCH_SCRATCH=""          # the mktemp dir holding those worktrees

say()  { printf '\033[38;5;103m🌫  %s\033[0m\n' "$*"; }
warn() { printf '\033[38;5;179m⚠  %s\033[0m\n' "$*"; }
die()  { printf '\033[38;5;167m✗  %s\033[0m\n' "$*" >&2; exit 1; }

repo_dir() { # repo_dir <name> — family repos live under ROOT; consumer + workshop elsewhere
  case "$1" in
    consumer) echo "$CONSUMER" ;;   # ~/.config/nix, outside the workshop dir
    workshop) echo "$ROOT" ;;       # the workshop IS ROOT, not ROOT/workshop
    *)        echo "$ROOT/$1" ;;
  esac
}

head_rev() { git -C "$(repo_dir "$1")" rev-parse HEAD 2>/dev/null || echo "?"; }

locked_rev() { # locked_rev <repo> <input> — what rev <repo>'s flake.lock pins <input> at
  python3 - "$(repo_dir "$1")/flake.lock" "$2" <<'EOF'
import json, sys
try:
    lock = json.load(open(sys.argv[1]))
    print(lock["nodes"][sys.argv[2]]["locked"]["rev"])
except Exception:
    print("?")
EOF
}

# The lock edges of the family graph: "<consumer-repo> <input-name> <source-repo>"
EDGES=(
  "pounce nebelung nebelung"
  "nebelhaus nebelung nebelung"
  "nebelhaus pounce pounce"
  "consumer nebelhaus nebelhaus"
)

host_name() { # the darwinConfiguration to build in the consumer flake
  if [ -n "${HAUS_HOST:-}" ]; then echo "$HAUS_HOST"; return; fi
  nix eval --json "$CONSUMER#darwinConfigurations" --apply builtins.attrNames 2>/dev/null \
    | python3 -c 'import json,sys; print(json.load(sys.stdin)[0])' 2>/dev/null \
    || hostname -s
}

# If we're running from inside a LINKED worktree of a family repo (a Claude
# agent's isolated checkout), note which repo and where. Works wherever the
# worktree physically lives: --git-common-dir always points at the main
# checkout's .git, and a linked worktree is exactly "toplevel != main".
WT_REPO="" WT_PATH=""
detect_worktree() {
  local top common main name
  top="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0
  common="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 0
  main="$(dirname "$common")"
  [ "$top" = "$main" ] && return 0
  for name in "${FAMILY[@]}"; do
    if [ "$main" = "$ROOT/$name" ]; then WT_REPO="$name" WT_PATH="$top"; return 0; fi
  done
}

local_src() { # local_src <repo> — the checkout to build against (batch- + worktree-aware)
  # A try-batch integration tree wins over everything: it's the combined
  # main+PRs checkout we deliberately built for this repo. Otherwise fall through
  # to the active agent worktree (if this repo is it), then the main checkout.
  if [ -n "${BATCH_SRC[$1]:-}" ]; then echo "${BATCH_SRC[$1]}"; return; fi
  if [ "$1" = "$WT_REPO" ]; then echo "$WT_PATH"; else echo "$ROOT/$1"; fi
}

overrides() { # every family input redirected at the local checkouts
  echo "--override-input nebelhaus path:$(local_src nebelhaus) \
        --override-input nebelhaus/nebelung path:$(local_src nebelung) \
        --override-input nebelhaus/pounce path:$(local_src pounce)"
}

# Release bookkeeping. Releases are what users actually consume — pounce via
# the Homebrew tap, nebelhaus via nebelhaus.com/init.sh (which serves the
# LATEST RELEASE's bootstrap, not main) — so a tag that falls behind main is
# every bit as stale as a lock edge, just invisible without this.
latest_tag() { # latest_tag <repo> — newest v* tag by version order, "" if none
  git -C "$(repo_dir "$1")" tag --list 'v*' --sort=-v:refname 2>/dev/null | head -1
}
commits_since() { # commits_since <repo> <ref> — commits on HEAD that <ref> lacks
  git -C "$(repo_dir "$1")" rev-list --count "$2..HEAD" 2>/dev/null || echo "?"
}

# Agent worktree bookkeeping, shared by status + ship.
list_worktrees() { # list_worktrees <repo> — linked worktree paths, one per line
  git -C "$(repo_dir "$1")" worktree list --porcelain 2>/dev/null \
    | awk '$1 == "worktree" { print $2 }' | tail -n +2
}
unmerged_agent_branches() { # worktree-* branches not merged into the current HEAD
  git -C "$(repo_dir "$1")" branch --list 'worktree-*' --no-merged HEAD \
    --format='%(refname:short)' 2>/dev/null
}

cmd_status() {
  say "repos"
  printf '  %-12s %-8s %-7s %s\n' "repo" "branch" "dirty" "vs origin"
  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || { printf '  %-12s (missing — bench clone)\n' "$name"; continue; }
    local branch dirty ahead behind
    branch="$(git -C "$dir" branch --show-current)"
    dirty="$(git -C "$dir" status --porcelain | wc -l | tr -d ' ')"
    [ "$dirty" = "0" ] && dirty="·" || dirty="${dirty} files"
    git -C "$dir" fetch -q --tags 2>/dev/null || true
    ahead="$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo '?')"
    behind="$(git -C "$dir" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo '?')"
    printf '  %-12s %-8s %-7s ↑%s ↓%s\n' "$name" "$branch" "$dirty" "$ahead" "$behind"
  done

  # Agent worktrees + their branches — only speak up if any exist.
  local wt_lines=""
  for name in "${FAMILY[@]}"; do
    local wt branch dirty
    while IFS= read -r wt; do
      [ -n "$wt" ] || continue
      branch="$(git -C "$wt" branch --show-current 2>/dev/null || echo '?')"
      dirty="$([ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ] && echo 'dirty' || echo '·')"
      wt_lines+="$(printf '  %-12s %-24s %-6s %s' "$name" "$branch" "$dirty" "$wt")"$'\n'
    done <<<"$(list_worktrees "$name")"
    local b
    for b in $(unmerged_agent_branches "$name"); do
      # branches whose worktree is gone but whose commits aren't merged yet
      if ! git -C "$(repo_dir "$name")" worktree list --porcelain | grep -q "branch refs/heads/$b"; then
        wt_lines+="$(printf '  %-12s %-24s %-6s %s' "$name" "$b" "·" "(parked — 'wt ${b#worktree-}' to resume, or open a PR / delete)")"$'\n'
      fi
    done
  done
  if [ -n "$wt_lines" ]; then
    echo
    say "agent worktrees (isolated Claude checkouts; open a PR to land — never push to main)"
    printf '  %-12s %-24s %-6s %s\n' "repo" "branch" "dirty" "where"
    printf '%s' "$wt_lines"
    # shellcheck disable=SC2016  # backticks are literal markdown, not command substitution
    printf '  \033[38;5;103m↳ landed ones linger if a pane was killed without the remove hook — sweep them with `wt reap`\033[0m\n'
  fi

  echo
  say "lock edges (is anyone consuming an old version of anyone?)"
  local stale=0
  for edge in "${EDGES[@]}"; do
    read -r holder input source <<<"$edge"
    local want have label
    want="$(head_rev "$source")"
    have="$(locked_rev "$holder" "$input")"
    label="$holder → $input"
    [ "$holder" = "consumer" ] && label="you → $input"
    if [ "$have" = "$want" ]; then
      printf '  ✓ %-22s current (%s)\n' "$label" "${have:0:7}"
    else
      printf '  ⚠ %-22s STALE: locked %s, local %s\n' "$label" "${have:0:7}" "${want:0:7}"
      stale=1
    fi
  done
  echo
  say "release edges (what new users actually get)"
  local rel_stale=0
  for name in pounce trill nebelhaus; do
    local dir tag behind audience
    dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue
    case "$name" in
      pounce)    audience="brew installs" ;;
      trill)     audience="brew installs" ;;
      nebelhaus) audience="nebelhaus.com/init.sh" ;;
    esac
    tag="$(latest_tag "$name")"
    if [ -z "$tag" ]; then
      printf '  ⚠ %-22s no release yet — %s falls back to main\n' "$name" "$audience"
      rel_stale=1
      continue
    fi
    behind="$(commits_since "$name" "$tag")"
    if [ "$behind" = "0" ]; then
      printf '  ✓ %-22s %s is current with main\n' "$name" "$tag"
    else
      printf '  ⚠ %-22s %s is %s commit(s) behind main — %s get the old one\n' \
        "$name" "$tag" "$behind" "$audience"
      # release date-stamps the version itself; nothing to bump by hand first.
      printf '      cut a dated release: bench release %s\n' "$name"
      rel_stale=1
    fi
  done

  echo
  if [ "$stale" = "1" ]; then
    warn "stale edges above. If the upstream work is committed: bench ship."
    warn "To test it on this machine without pushing anything: bench try"
  elif [ "$rel_stale" = "1" ]; then
    warn "locks are current, but a release is behind — ship is done, releasing is the last mile."
  else
    say "everything is current. The fog is even."
  fi
}

cmd_try() {
  local host; host="$(host_name)"
  detect_worktree
  if [ -n "$WT_REPO" ]; then
    if [ "${1:-}" = "switch" ]; then
      die "refusing to switch from an agent worktree of $WT_REPO — only the main checkouts get activated. Land the branch via its PR, then try/switch from the main checkout."
    fi
    say "you're in an agent worktree — overriding $WT_REPO with $WT_PATH"
  fi
  say "building $host against the LOCAL checkouts (uncommitted edits included)…"
  # shellcheck disable=SC2046
  (cd "$CONSUMER" && nix build ".#darwinConfigurations.$host.system" $(overrides))
  say "build OK — nothing pushed, nothing activated."
  if [ "${1:-}" = "switch" ]; then
    say "switching (this activates the LOCAL build on this machine)…"
    # Activate via the stable /run/current-system path, not ./result: the
    # collar module's passwordless-sudo rule matches that literal path (sudo no
    # longer follows the command symlink), and the built system's own `activate`
    # script runs either way, so the result is identical.
    # shellcheck disable=SC2046
    (cd "$CONSUMER" && sudo /run/current-system/sw/bin/darwin-rebuild switch --flake ".#$host" $(overrides))
    warn "you are now running unpushed code. When happy: commit + bench ship,"
    warn "so a plain rebuild reproduces what you're running."
  else
    say "to activate it too: bench try switch"
  fi
}

# ── bench try-batch: feel-test the whole review queue in ONE rebuild ─────────
# Activating a machine is serial — one `darwin-rebuild switch` = one machine
# state — so you can only feel-test one feature at a time. The tempting shortcut
# (merge every ready PR to main, THEN rebuild and tick them off) puts unverified
# code on main before you've felt it, so a bug you find is already landed.
# try-batch inverts that: for each repo it builds a THROWAWAY integration tree
# (the main checkout's committed HEAD + every open PR merged in), overrides the
# flake at those trees, and builds/activates the combined result ONCE. main is
# never touched; you test the whole queue in a single rebuild, then merge only
# the PRs that passed and leave the rest open. It ends by printing the PRs as a
# tick-off checklist — each PR's own body carries its Verify steps (see the ship
# skill), so open the PR to know what to check. A PR that conflicts with the
# batch (or is a fork whose head isn't on origin) is dropped — with a warning AND
# a "dropped" footer under the checklist, never silently — so it can't quietly
# vanish from the summary; test that one on its own branch.
cleanup_batch() { # remove every integration worktree + the scratch dir (EXIT trap)
  local repo
  if [ "${#BATCH_SRC[@]}" -gt 0 ]; then
    for repo in "${!BATCH_SRC[@]}"; do
      git -C "$(repo_dir "$repo")" worktree remove --force "${BATCH_SRC[$repo]}" 2>/dev/null || true
    done
  fi
  [ -n "$BATCH_SCRATCH" ] && rm -rf "$BATCH_SCRATCH"
  return 0
}

cmd_try_batch() {
  local do_switch=""
  if [ "${1:-}" = "switch" ]; then do_switch=1; shift; fi
  command -v gh >/dev/null 2>&1 || die "bench try-batch needs the gh CLI to find your open PRs."

  # Which repos to sweep: any overridable repos named as args, else all of them.
  # trill isn't a flake input, so overriding it does nothing — reject it loudly.
  local -a want_repos=()
  if [ "$#" -gt 0 ]; then
    local a
    for a in "$@"; do
      if printf '%s\n' "${OVERRIDABLE[@]}" | grep -qx "$a"; then
        want_repos+=("$a")
      else
        warn "skipping '$a' — not a flake-overridable repo (batchable: ${OVERRIDABLE[*]})."
      fi
    done
    [ "${#want_repos[@]}" -gt 0 ] || die "nothing overridable to batch."
  else
    want_repos=("${OVERRIDABLE[@]}")
  fi

  local host; host="$(host_name)"
  BATCH_SCRATCH="$(mktemp -d "${TMPDIR:-/tmp}/bench-batch.XXXXXX")"
  trap cleanup_batch EXIT

  local -a checklist=() dropped=()
  local repo
  for repo in "${want_repos[@]}"; do
    local dir; dir="$(repo_dir "$repo")"
    [ -d "$dir/.git" ] || continue
    # Open PRs, as "num<TAB>head<TAB>title<TAB>url" lines. gh's own --jq keeps
    # us from shelling out to jq.
    local prs
    prs="$(gh pr list --repo "$GH_ORG/$repo" --state open \
             --json number,headRefName,title,url \
             --jq '.[] | [.number, .headRefName, .title, .url] | @tsv' 2>/dev/null || true)"
    [ -n "$prs" ] || continue

    say "$repo: integrating $(printf '%s\n' "$prs" | grep -c '') open PR(s) onto main's HEAD…"
    git -C "$dir" fetch -q origin 2>/dev/null || true
    local wtdir="$BATCH_SCRATCH/$repo"
    git -C "$dir" worktree add -q --detach "$wtdir" HEAD

    local num head title url included=0
    while IFS=$'\t' read -r num head title url; do
      [ -n "$num" ] || continue
      if ! git -C "$wtdir" rev-parse -q --verify "origin/$head^{commit}" >/dev/null 2>&1; then
        warn "$repo: can't find origin/$head (fork PR?) — skipping #$num."
        dropped+=("$(printf '      %-10s #%-4s %s' "$repo" "$num" "$title")")
        dropped+=("$(printf '                  fork PR (head not on origin) — %s' "$url")")
        continue
      fi
      if git -C "$wtdir" merge --no-edit "origin/$head" >/dev/null 2>&1; then
        checklist+=("$(printf '  [ ] %-10s #%-4s %s' "$repo" "$num" "$title")")
        checklist+=("$(printf '                  %s' "$url")")
        included=$((included + 1))
      else
        git -C "$wtdir" merge --abort 2>/dev/null || true
        warn "$repo: dropping #$num ($head) — it conflicts with the batch; test it on its own."
        dropped+=("$(printf '      %-10s #%-4s %s' "$repo" "$num" "$title")")
        dropped+=("$(printf '                  conflicts with the batch — %s' "$url")")
      fi
    done <<<"$prs"

    if [ "$included" -gt 0 ]; then
      BATCH_SRC["$repo"]="$wtdir"
    else
      git -C "$dir" worktree remove --force "$wtdir" 2>/dev/null || true
    fi
  done

  if [ "${#BATCH_SRC[@]}" -eq 0 ]; then
    if [ "${#dropped[@]}" -gt 0 ]; then
      warn "every open PR was dropped from the batch (conflicts/forks) — nothing to build:"
      printf '%s\n' "${dropped[@]}"
      warn "test each on its own branch (bench try from its worktree)."
    else
      say "no open PRs to batch — nothing to do (plain 'bench try' tests the pinned tree)."
    fi
    return 0
  fi

  say "building $host against ${#BATCH_SRC[@]} batched integration tree(s)…"
  # shellcheck disable=SC2046
  (cd "$CONSUMER" && nix build ".#darwinConfigurations.$host.system" $(overrides))
  say "build OK — nothing pushed, nothing merged, main untouched."

  if [ -n "$do_switch" ]; then
    say "switching (activates the COMBINED unmerged batch on this machine)…"
    # shellcheck disable=SC2046
    (cd "$CONSUMER" && sudo /run/current-system/sw/bin/darwin-rebuild switch --flake ".#$host" $(overrides))
    warn "you are now running a COMBINATION of unmerged branches — none of it is on main."
  fi

  echo
  say "test checklist — verify each PR (steps are in its body), then merge only the winners:"
  printf '%s\n' "${checklist[@]}"
  if [ "${#dropped[@]}" -gt 0 ]; then
    echo
    warn "dropped from the batch — NOT built above; test each on its own branch:"
    printf '%s\n' "${dropped[@]}"
  fi
  echo
  warn "none of these are merged. gh pr merge the ones that pass; leave the rest open."
}

cmd_ship() {
  # Walk the chain upstream→downstream. For each repo: refuse dirty trees
  # (your commits are yours to write), bump any stale family locks, push.
  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue
    if [ -n "$(git -C "$dir" status --porcelain)" ]; then
      git -C "$dir" status --short
      die "$name has uncommitted changes — commit (or stash) them first, then re-run bench ship."
    fi
  done

  # Agent branches never block a ship (main is main), but don't let them rot silently.
  for name in "${FAMILY[@]}"; do
    local unmerged; unmerged="$(unmerged_agent_branches "$name" | tr '\n' ' ')"
    if [ -n "${unmerged// /}" ]; then
      warn "$name has unmerged agent branches (not shipping them — open a PR to land): $unmerged"
    fi
  done

  for name in "${FAMILY[@]}" consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue

    # Bump this repo's locks for any upstream family input that moved.
    local bumped=()
    for edge in "${EDGES[@]}"; do
      read -r holder input source <<<"$edge"
      [ "$holder" = "$name" ] || continue
      if [ "$(locked_rev "$holder" "$input")" != "$(head_rev "$source")" ]; then
        say "$name: updating lock for ${input}…"
        (cd "$dir" && nix flake update "$input")
        bumped+=("$input")
      fi
    done
    if [ "${#bumped[@]}" -gt 0 ]; then
      (cd "$dir" && git add flake.lock && git commit -m "Update flake inputs (${bumped[*]})")
    fi

    # Push if there's anywhere to push to and anything to push.
    if git -C "$dir" rev-parse '@{u}' >/dev/null 2>&1; then
      local ahead; ahead="$(git -C "$dir" rev-list --count '@{u}..HEAD')"
      if [ "$ahead" != "0" ]; then
        say "$name: pushing $ahead commit(s)…"
        git -C "$dir" push
      fi
    fi
  done

  say "shipped. Apply it to this machine with: bench rebuild"
}

# ── Claude Code agent worktrees ─────────────────────────────────────────────
# The worktree lifecycle — create on `claude --worktree`, save-on-close, and
# list/resume — used to live here, but it isn't family business: it's a standalone,
# repo-agnostic tool now, `wt`, that ships in the RICE (nebelhaus/modules/den,
# next to `haus`) on PATH, wired into Claude Code's WorktreeCreate/WorktreeRemove
# hooks — because the rice already ships the `claude --worktree` keybinds. bench
# no longer owns it — not every machine that runs `wt` has bench. To see or resume
# parked/live agent worktrees across ALL repos, run `wt` (or `wt <name>`).
# bench still *reports* family worktrees in `bench status`; it just doesn't drive
# their lifecycle.

cmd_rebuild() {
  local host; host="$(host_name)"
  say "pinned rebuild of $host from ${CONSUMER}…"
  (cd "$CONSUMER" \
    && nix build ".#darwinConfigurations.$host.system" \
    && sudo /run/current-system/sw/bin/darwin-rebuild switch --flake ".#$host")
  say "the house stands."
}

cmd_pull() {
  # workshop first (bench itself lives here — a stale clone is how a merged PR
  # ambushes the next push). org-profile + homebrew-tap are CI-owned but still
  # want a fresh local checkout: `bench status` diffs them, and a stale
  # homebrew-tap clone hides cask/formula bumps CI already pushed (the
  # "released but not installed" trap). Superset of cmd_ship's repo set.
  for name in workshop "${FAMILY[@]}" org-profile homebrew-tap consumer; do
    local dir; dir="$(repo_dir "$name")"
    [ -d "$dir/.git" ] || continue
    say "pulling ${name}…"
    git -C "$dir" pull --ff-only || warn "$name: couldn't fast-forward; resolve by hand"
  done
}

version_file() { # version_file <repo> — WHERE a releasable repo's version lives
  case "$1" in
    pounce)    echo "$(repo_dir "$1")/pkgs/pounce/default.nix" ;;
    trill)     echo "$(repo_dir "$1")/VERSION" ;;
    nebelhaus) echo "$(repo_dir "$1")/VERSION" ;;
    *) return 1 ;;
  esac
}

read_version() { # read_version <repo> — the version string that repo tags at
  local f; f="$(version_file "$1")" || return 1
  case "$1" in
    pounce)    sed -n 's/^ *version = "\([^"]*\)";.*/\1/p' "$f" | head -1 ;;
    trill)     tr -d '[:space:]' < "$f" 2>/dev/null ;;
    nebelhaus) tr -d '[:space:]' < "$f" 2>/dev/null ;;
  esac
}

write_version() { # write_version <repo> <version> — stamp the version source in place
  local f; f="$(version_file "$1")" || return 1
  case "$1" in
    # Only the declaration line matches ^ *version = "…"; the POUNCE_VERSION="$version"
    # line below it starts with POUNCE_, so it's left untouched. Written via a temp
    # file rather than `sed -i` — GNU (Linux/CI) and BSD (macOS) disagree on the
    # -i suffix arg, so the portable path is redirect + mv.
    pounce)    local t; t="$(mktemp)"; sed -E "s/^( *version = \")[^\"]*(\";.*)/\1$2\2/" "$f" >"$t" && mv "$t" "$f" ;;
    trill)     printf '%s\n' "$2" > "$f" ;;
    nebelhaus) printf '%s\n' "$2" > "$f" ;;
  esac
}

# Date-based versions (CalVer). A release is stamped with the day it's cut —
# YYYY.MM.DD — never a hand-typed semver. A second release on the same day gets
# a -N disambiguator (…-1, …-2); git version-sort and Homebrew both order that
# AFTER the bare date, so `latest_tag` and "vs main" stay right.
today_version() { date +%Y.%m.%d; }

next_version() { # next_version <repo> — today's date, with -N if today's already tagged
  local dir base n; dir="$(repo_dir "$1")"; base="$(today_version)"
  git -C "$dir" fetch -q --tags 2>/dev/null || true
  if ! git -C "$dir" rev-parse -q --verify "refs/tags/v$base" >/dev/null; then
    echo "$base"; return
  fi
  n=1
  while git -C "$dir" rev-parse -q --verify "refs/tags/v$base-$n" >/dev/null; do
    n=$((n + 1))
  done
  echo "$base-$n"
}

cmd_release() {
  # Cut a release: stamp today's date as the version, commit it into the repo's
  # own version source (so the tag can't drift from what the code says — CI
  # double-checks anyway), push, then tag v<version>. The tag push is the
  # button; CI does the rest: GitHub release + source tarball + a version bump
  # in homebrew-tap (which is CI-owned — never hand-bump it). No number is ever
  # typed by hand — the date IS the version. Division of labor: feature commits
  # are yours, lock bumps are ship's, the date-stamp + tag are release's,
  # formula bumps are CI's.
  local name="${1:-}"
  [ -n "$name" ] || die "usage: bench release <repo>   (releasable: pounce, trill, nebelhaus)"

  local dir; dir="$(repo_dir "$name")"
  [ -d "$dir/.git" ] || die "$name is not cloned here — bench clone"
  local verfile
  verfile="$(version_file "$name")" \
    || die "bench release doesn't know '$name' yet (releasable: pounce, trill, nebelhaus)"
  [ -z "$(git -C "$dir" status --porcelain)" ] \
    || die "$name is dirty — commit (and bench ship) first"
  git -C "$dir" fetch -q --tags 2>/dev/null || true
  local ahead; ahead="$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null || echo '?')"
  [ "$ahead" = "0" ] || die "$name has unpushed commits — bench ship first, then release"

  # Stamp today's date (YYYY.MM.DD, or …-N on a same-day repeat) into the
  # version source and commit it, so HEAD already says what the tag will claim.
  local version tag
  version="$(next_version "$name")"
  tag="v$version"
  write_version "$name" "$version"
  if ! git -C "$dir" diff --quiet -- "$verfile"; then
    say "$name: stamping version ${version}…"
    git -C "$dir" add "$verfile"
    git -C "$dir" commit -m "$name $version"
    git -C "$dir" rev-parse '@{u}' >/dev/null 2>&1 && git -C "$dir" push
  fi

  say "releasing $name $tag — pushing the tag; CI takes it from here…"
  git -C "$dir" tag -a "$tag" -m "$name $version"
  git -C "$dir" push origin "$tag"
  say "watch it: https://github.com/$GH_ORG/$name/actions  (release → tap bump)"
  warn "the date-stamp moved $name's HEAD — run bench ship to ripple its lock downstream."
}

# ── docs-since ────────────────────────────────────────────────────────────────
# What has changed since the docs were last reconciled? Every repo carries a
# watermark in .docs-sync.json; this prints the commits past it, so the daily
# docs sweep never re-reads what it already read and never misses a day it slept
# through.
#
# The state file is COMMITTED, not gitignored: the sweep runs as a claude.ai
# routine in a throwaway Linux container, so anything it needs to remember
# between runs has to live in the repo. That also makes the watermark a visible
# record of how far the docs have been reconciled.
DOCS_STATE="$ROOT/.docs-sync.json"

# Every repo whose commits can invalidate a doc — the flake family, plus the
# workshop itself (bench/README/web live here) and the two CI-owned leaves.
DOCS_REPOS=(workshop "${FAMILY[@]}" org-profile homebrew-tap)

docs_watermark() { # docs_watermark <repo> — last reconciled rev, "" if never
  [ -f "$DOCS_STATE" ] || { echo ""; return; }
  python3 - "$DOCS_STATE" "$1" <<'EOF'
import json, sys
try:
    print(json.load(open(sys.argv[1])).get("repos", {}).get(sys.argv[2], {}).get("rev", ""))
except Exception:
    print("")
EOF
}

cmd_docs_since() {
  local mark="" any=0
  [ "${1:-}" = "--mark" ] && mark=1

  for name in "${DOCS_REPOS[@]}"; do
    local dir
    if [ "$name" = workshop ]; then dir="$ROOT"; else dir="$(repo_dir "$name")"; fi
    [ -d "$dir/.git" ] || continue
    local head; head="$(git -C "$dir" rev-parse HEAD)"
    local base; base="$(docs_watermark "$name")"

    # Never reconciled, or the watermark was rewritten away? Fall back to a
    # day's worth of history rather than replaying the repo from its birth.
    if [ -z "$base" ] || ! git -C "$dir" cat-file -e "$base^{commit}" 2>/dev/null; then
      base="$(git -C "$dir" rev-list -1 --before='1 day ago' HEAD 2>/dev/null || echo "")"
    fi
    [ "$base" = "$head" ] && continue

    local range; range="$([ -n "$base" ] && echo "$base..HEAD" || echo HEAD)"
    # Skip the sweep's OWN commits. Doc PRs land on main like anything else, so
    # without this the routine reads yesterday's output as today's input — every
    # day, forever. The skill stamps each of its commits with a Docs-Sync
    # trailer precisely so they can be filtered back out here.
    local skip_own=(--invert-grep --grep='^Docs-Sync: ')
    local log; log="$(git -C "$dir" log --no-merges "${skip_own[@]}" \
      --format='  %h %ad %s' --date=short "$range" 2>/dev/null)"
    [ -n "$log" ] || continue

    any=1
    say "$name  ($(printf '%s\n' "$log" | grep -c .) commits)"
    printf '%s\n' "$log"
    printf '  \033[38;5;245mfiles:\033[0m %s\n\n' \
      "$(git -C "$dir" diff --name-only "$range" 2>/dev/null | head -40 | tr '\n' ' ')"
  done

  [ "$any" = 1 ] || say "nothing new since the last docs sweep."

  if [ -n "$mark" ]; then
    python3 - "$DOCS_STATE" "$ROOT" "$CONSUMER" "${DOCS_REPOS[@]}" <<'EOF'
import json, subprocess, sys, datetime
state_path, root, consumer, *repos = sys.argv[1:]
state = {"repos": {}}
try:
    state = json.load(open(state_path))
    state.setdefault("repos", {})
except Exception:
    pass
for name in repos:
    d = root if name == "workshop" else f"{root}/{name}"
    # Mark `main`, never HEAD. A sweep ends sitting on its own docs-sync-* PR
    # branch, and recording that tip would park the watermark on a commit main
    # doesn't contain — every later run then re-reads from a bogus base. main is
    # also the right ANSWER: the watermark tracks the source commits we've read,
    # and those land on main; the doc PR is this sweep's output, not its input.
    try:
        rev = subprocess.check_output(["git", "-C", d, "rev-parse", "main"], text=True).strip()
    except Exception:
        try:
            rev = subprocess.check_output(["git", "-C", d, "rev-parse", "HEAD"], text=True).strip()
        except Exception:
            continue
    state["repos"][name] = {"rev": rev}
state["last_run"] = datetime.datetime.now().astimezone().isoformat(timespec="seconds")
json.dump(state, open(state_path, "w"), indent=2)
open(state_path, "a").write("\n")
EOF
    say "watermarks recorded — next sweep starts from here."
  fi
}

cmd_clone() {
  for name in "${FAMILY[@]}" org-profile homebrew-tap; do
    local repo="$name"
    [ "$name" = "org-profile" ] && repo=".github"
    if [ -d "$ROOT/$name/.git" ]; then
      say "$name already here"
    else
      say "cloning ${name}…"
      git clone "https://github.com/$GH_ORG/$repo.git" "$ROOT/$name"
    fi
  done
}

# When sourced with HAUS_LIB=1 (the bats test harness), stop here: the caller
# just wants the functions above, not to dispatch a command.
if [ "${HAUS_LIB:-}" != "1" ]; then
case "${1:-status}" in
  status)  cmd_status ;;
  try)     cmd_try "${2:-}" ;;
  try-batch) shift; cmd_try_batch "$@" ;;
  ship)    cmd_ship ;;
  rebuild) cmd_rebuild ;;
  pull)    cmd_pull ;;
  clone)   cmd_clone ;;
  docs-since) cmd_docs_since "${2:-}" ;;
  release) cmd_release "${2:-}" ;;
  *)       sed -n '2,31p' "$0" | sed 's/^# \{0,1\}//'; exit 1 ;;
esac
fi
